{
  "$ref": "#/definitions/template-blocks",
  "definitions": {
    "template-blocks": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "blockId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "category": {
          "type": "string",
          "enum": [
            "warranty",
            "permission",
            "condition",
            "disclaimer",
            "notice"
          ]
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "blockTitle": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "blockId",
        "category",
        "version"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}