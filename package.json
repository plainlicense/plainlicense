{
  "author": {
    "email": "adam@plainlicense.org",
    "name": "Adam Poulemanos"
  },
  "bin": {
    "install-hooks": "bin/install-hooks.sh",
    "setup-repo": "bin/setup-repo.sh"
  },
  "bugs": {
    "email": "adam@plainlicense.org",
    "url": "https://github.com/plainlicense/plainlicense/issues"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/starlight": "^0.37.6",
    "@sveltia/cms": "^0.144.5",
    "plain-license-elastic-2.0": "workspace:plain-license-elastic-2.0",
    "plain-license-mit": "workspace:plain-license-mit",
    "plain-license-mpl-2.0": "workspace:plain-license-mpl-2.0",
    "plain-license-unlicense": "workspace:plain-license-unlicense",
    "rxjs": "^7.8.2",
    "starlight-markdown": "^0.1.5"
  },
  "description": "Plain language versions of popular creative licenses",
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/cz-commitlint": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@testing-library/preact": "^3.2.4",
    "@tsconfig/bun": "^1.0.8",
    "@types/bun": "^1.2.16",
    "@types/css-modules": "^1.0.5",
    "@types/dom-navigation": "^1.0.5",
    "@types/node": "^24.12.0",
    "@types/resize-observer-browser": "^0.1.11",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "astro": "^5.18.0",
    "astro-favicons": "^3.1.6",
    "autoprefixer": "^10.4.21",
    "bun": "^1.2.16",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.3",
    "commitlint-plugin-selective-scope": "^1.0.1",
    "github-types": "^1.0.0",
    "globby": "^16.1.1",
    "gray-matter": "^4.0.3",
    "issue-parser": "^7.0.1",
    "markdownlint-cli2": "^0.21.0",
    "marked": "^17.0.4",
    "playwright": "^1.53.0",
    "preact": "^10.28.4",
    "satori": "^0.25.0",
    "semantic-release": "^25.0.3",
    "semantic-release-cli": "^5.4.6",
    "semantic-release-monorepo": "^8.0.2",
    "sharp": "^0.34.5",
    "starlight-auto-drafts": "^0.2.1",
    "starlight-blog": "^0.25.3",
    "starlight-contextual-menu": "^0.1.5",
    "starlight-heading-badges": "^0.6.1",
    "starlight-llms-txt": "^0.7.0",
    "starlight-scroll-to-top": "0.4.0",
    "starlight-tags": "^0.4.0",
    "svgo": "^4.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "directories": {
    "assets": "src/assets",
    "build-source": "src/build",
    "ci": ".github",
    "custom-theme": "overrides",
    "dev-container": ".devcontainer",
    "hooks": "overrides/hooks",
    "packages": "packages",
    "scripts": "bin",
    "site": "docs",
    "source": "src",
    "submodules": "external"
  },
  "engines": {
    "node": ">= 20"
  },
  "keywords": [
    "legal",
    "license",
    "mkdocs",
    "mit",
    "mpl",
    "unlicense",
    "readability",
    "mkdocs-material",
    "plain-language",
    "language"
  ],
  "license": "Unlicense",
  "name": "plain-license",
  "peerDependencies": {
    "@commitlint/lint": "^20.4.3",
    "semantic-release": "^25.0.3"
  },
  "private": true,
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "extends": "semantic-release-monorepo",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": "patch",
              "type": "fix"
            },
            {
              "release": "patch",
              "type": "refactor"
            },
            {
              "release": "minor",
              "scope": "content",
              "type": "new"
            },
            {
              "release": "patch",
              "scope": "ui",
              "type": "new"
            },
            {
              "release": "patch",
              "type": "new"
            },
            {
              "release": "patch",
              "scope": "scripts"
            },
            {
              "release": false,
              "type": "bot"
            },
            {
              "release": false,
              "type": "chore"
            },
            {
              "release": false,
              "scope": "infra"
            },
            {
              "release": false,
              "scope": "deps"
            },
            {
              "release": false,
              "scope": "blog"
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator"
      ],
      [
        "@semantic-release/github"
      ]
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plainlicense/plainlicense.git"
  },
  "scripts": {
    "build": "mise run build",
    "check": "mise run lint",
    "ci": "mise run ci",
    "commit": "mise run commit",
    "deploy": "mise run deploy",
    "dev": "mise run dev",
    "format": "mise run fmt",
    "preview": "mise run preview",
    "release": "mise run release",
    "serve": "mise run serve",
    "setup": "mise run setup",
    "sync": "mise run sync",
    "test": "mise run test",
    "test:coverage": "mise run test-cov",
    "test:e2e": "mise run test --e2e",
    "test:ui": "mise run test --ui",
    "test:unit": "mise run test --unit",
    "update": "mise run update"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core"
  ],
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ]
}