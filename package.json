    "uglify": "^0.1.5"
  },
  "directories": {
    "assets": "src/assets",
    "build-source": "src/build",
    "ci": ".github",
    "custom-theme": "overrides",
    "dev-container": ".devcontainer",
    "hooks": "overrides/hooks",
    "packages": "packages",
    "scripts": "bin",
    "site": "docs",
    "source": "src",
    "submodules": "external"
  },
  "engines": {
    "node": ">= 20"
  },
  "keywords": [
    "legal",
    "license",
    "mkdocs",
    "mit",
    "mpl",
    "unlicense",
    "readability",
    "mkdocs-material",
    "plain-language",
    "language"
  ],
  "license": "Unlicense",
  "main": "packages/plainlicense",
  "name": "plain-license",
  "peerDependencies": {
    "@commitlint/lint": "^19.8.1",
    "semantic-release": "^24.2.5"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "embeddedLanguageFormatting": "auto",
    "endOfLine": "lf",
    "experimentalTernaries": true,
    "htmlWhitespaceSensitivity": "css",
    "overrides": [
      {
        "files": ["*.md", "*.html"],
        "options": {
          "printWidth": 80,
          "proseWrap": "always",
          "singleQuote": false,
          "tabWidth": 2,
          "trailingComma": "none",
          "useTabs": false
        }
      },
      {
        "files": ["*.json", "*.jsonc", "*.json5", "*.jsonl"],
        "options": {
          "parser": "json",
          "tabWidth": 2,
          "useTabs": false
        }
      },
      {
        "files": ["overrides/*.html"],
        "options": {
          "parser": "jinja-template"
        }
      },
      {
        "files": ["bin/*.sh"],
        "options": {
          "parser": "sh"
        }
      },
      {
        "files": ["*.toml"],
        "options": {
          "parser": "toml"
        }
      }
    ],
    "plugins": [
      "prettier-plugin-sh",
      "prettier-plugin-jinja-template",
      "prettier-plugin-toml",
      "prettier-plugin-packagejson"
    ],
    "printWidth": 100,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false
  },
  "private": true,
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "extends": "semantic-release-monorepo",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": "patch",
              "type": "fix"
            },
            {
              "release": "patch",
              "type": "refactor"
            },
            {
              "release": "minor",
              "scope": "content",
              "type": "new"
            },
            {
              "release": "patch",
              "scope": "ui",
              "type": "new"
            },
            {
              "release": "patch",
              "type": "new"
            },
            {
              "release": "patch",
              "scope": "scripts"
            },
            {
              "release": false,
              "type": "bot"
            },
            {
              "release": false,
              "type": "chore"
            },
            {
              "release": false,
              "scope": "infra"
            },
            {
              "release": false,
              "scope": "deps"
            },
            {
              "release": false,
              "scope": "blog"
            }
          ]
        }
      ],
      ["@semantic-release/release-notes-generator"],
      ["@semantic-release/github"]
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plainlicense/plainlicense.git"
  },
  "scripts": {
    "all": "make all",
    "build": "make build",
    "check": "make check",
    "ci": "make ci",
    "cm": "make cm",
    "commit": "make cm",
    "deploy": "make deploy",
    "fix": "make fix",
    "format": "make format",
    "help": "make help",
    "release": "make release",
    "release-dev": "make release-dev",
    "serve": "make serve",
    "setup": "make setup",
    "sync": "make sync",
    "upgrade": "make upgrade"
  },
  "trustedDependencies": ["@parcel/watcher", "@swc/core"],
  "version": "0.0.0-development",
  "workspaces": ["packages/*"]
}
