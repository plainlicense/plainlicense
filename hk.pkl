amends "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/Builtins.pkl"
import "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/builtins/stylelint.pkl"

/// Are we in a GitHub Actions environment?
local function isCi() =
  (read?("env:CI")?.toBoolean() ?? false) && (read?("env:GITHUB_ACTIONS")?.toBoolean() ?? false)

// If running on GitHub Actions, we use `--changed` to limit the files to those changed compared to the default branch.
local biomeFileLimiter = if (isCi()) "--changed" else "--staged"

local linters = new Mapping<String, Step> {
  ["actionlint"] = Builtins.actionlint

  ["biome"] = Builtins.biome

  ["markdownlint"] = Builtins.markdown_lint

  ["shellcheck"] = Builtins.shellcheck

  ["shfmt"] = Builtins.shfmt

  ["yq"] = (Builtins.yq) {
    glob = List("*.{yaml,yml}")
  }

  // Spellchecker
  ["typos"] = Builtins.typos
}

hooks {
  ["fix"] {
    fix = true // automatically modify files with available linter fixes
    stash = "git" // stashes unstaged changes while running fix steps
    steps = linters
  }

  ["check"] {
    steps = linters
  }
}
