# GitHub OAuth Proxy configuration
OAUTH_GITHUB_CLIENT_ID=your_id
OAUTH_GITHUB_CLIENT_SECRET=your_secret
AUTH_PROXY_URL=https://auth.plainlicense.org

# Build performance
PARALLEL_PDF_GENERATION=true
MAX_CONCURRENT_TYPST=10
INCREMENTAL_EXPORTS=true

# Public site URL
PUBLIC_SITE_URL=https://plainlicense.org
