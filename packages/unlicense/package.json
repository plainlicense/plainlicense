{
  "name": "plain-license-unlicense",
  "version": "0.2.0",
  "private": true,
  "description": "Plain language version of the Unlicense",
  "main": "../../docs/licenses/public-domain/unlicense/index.md",
  "scripts": {
    "release": "semantic-release"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "new"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": false,
              "type": "bot"
            }
          ]
        }
      ],
      [
        [
          "@semantic-release/release-notes-generator"
        ],
        [
          "@semantic-release/github"
        ],
        {
          "assets": [
            {
              "path": "../../docs/licenses/public-domain/unlicense/index.md",
              "label": "Plain Unlicense License"
            }
          ]
        },
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/unlicense.md",
          "changelogTitle": "Plain Unlicense Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "../changelogs/unlicense.md"
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1"
  }
}
