{
  "author": {
    "email": "adam@plainlicense.org",
    "name": "Adam Poulemanos",
    "url": "https://plainlicense.org"
  },
  "description": "Plain language adaptation of the Unlicense",
  "devDependencies": {
    "@commitlint/cli": "catalog:license-release",
    "@semantic-release/changelog": "catalog:license-release",
    "@semantic-release/commit-analyzer": "catalog:license-release",
    "@semantic-release/git": "catalog:license-release",
    "@semantic-release/github": "catalog:license-release",
    "@semantic-release/release-notes-generator": "catalog:license-release",
    "commitlint-plugin-selective-scope": "catalog:license-release",
    "semantic-release": "catalog:license-release",
    "semantic-release-cli": "catalog:license-release"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "onFail": "download",
      "version": "catalog:"
    }
  },
  "displayName": "Plain Unlicense",
  "homepage": "https://plainlicense.org/unlicense/",
  "keywords": [
    "plainlicense",
    "plain language",
    "license",
    "licensing"
  ],
  "license": "LicenseRef-PlainUnlicense OR Unlicense",
  "main": "../../content/licenses/public-domain/unlicense.md",
  "name": "@plainlicense/plain-unlicense",
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "new"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": false,
              "type": "bot"
            }
          ]
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/unlicense.md",
          "changelogTitle": "Plain Unlicense Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "../changelogs/unlicense.md"
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator"
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "label": "Plain Unlicense (GitHub Markdown)",
              "path": "../../dist/exports/unlicense/${nextRelease.version}/Plain-Unlicense-${nextRelease.version}.gfm.md"
            },
            {
              "label": "Plain Unlicense (Markdown)",
              "path": "../../dist/exports/unlicense/${nextRelease.version}/Plain-Unlicense-${nextRelease.version}.cm.md"
            },
            {
              "label": "Plain Unlicense (PDF)",
              "path": "../../dist/exports/unlicense/${nextRelease.version}/Plain-Unlicense-${nextRelease.version}.pdf"
            },
            {
              "label": "Plain Unlicense (Plaintext)",
              "path": "../../dist/exports/unlicense/${nextRelease.version}/Plain-Unlicense-${nextRelease.version}.txt"
            }
          ]
        }
      ]
    ]
  },
  "repository": {
    "directory": "packages/unlicense",
    "type": "git",
    "url": "git+https://github.com/plainlicense/plainlicense.git"
  },
  "scripts": {
    "release": "bunx semantic-release"
  }
}
