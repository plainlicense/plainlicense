{
  "description": "Plain language version of Elastic License 2.0",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1"
  },
  "main": "../../docs/licenses/source-available/elastic-2.0/index.md",
  "name": "plain-license-elastic-2.0",
  "private": true,
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "new"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": false,
              "type": "bot"
            }
          ]
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/unlicense.md",
          "changelogTitle": "Plain Elastic 2.0 Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": ["../changelogs/elastic-2.0.md"]
        }
      ],
      ["@semantic-release/release-notes-generator"],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "label": "Plain Elastic License 2.0",
              "path": "../../docs/licenses/source-available/elastic-2.0/index.md"
            }
          ]
        }
      ]
    ]
  },
  "scripts": {
    "release": "semantic-release"
  },
  "version": "0.1.0"
}
