{
  "name": "plain-license-elastic-2.0",
  "version": "0.1.0",
  "private": true,
  "description": "Plain language version of Elastic License 2.0",
  "main": "../../content/licenses/source-available/elastic-2.0.md",
  "scripts": {
    "release": "semantic-release"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "name": "dev",
        "prerelease": true,
        "channel": "pre/rc"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "stable",
              "release": "major"
            },
            {
              "type": "new",
              "release": "minor"
            },
            {
              "type": "subs",
              "release": "minor"
            },
            {
              "type": "admin",
              "release": "patch"
            },
            {
              "type": "bot",
              "release": false
            }
          ]
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/elastic-2.0.md",
          "changelogTitle": "Plain Elastic 2.0 Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "../changelogs/elastic-2.0.md"
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator"
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.gfm.md",
              "label": "Plain Elastic License 2.0 (Markdown)"
            },
            {
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.pdf",
              "label": "Plain Elastic License 2.0 (PDF)"
            },
            {
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.txt",
              "label": "Plain Elastic License 2.0 (Plaintext)"
            }
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1"
  }
}
