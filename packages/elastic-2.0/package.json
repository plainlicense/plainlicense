{
  "name": "@plainlicense/plain-elastic",
  "displayName": "Plain Elastic License",
  "version": "0.1.0",
  "description": "Plain language adaptation of Elastic License 2.0",
  "keywords": [
    "plainlicense",
    "plain language",
    "license",
    "licensing"
  ],
  "homepage": "https://plainlicense.org/elastic-20/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plainlicense/plainlicense.git",
    "directory": "packages/elastic-2.0"
  },
  "license": "LicenseRef-PlainUnlicense OR Unlicense",
  "author": {
    "name": "Adam Poulemanos",
    "email": "adam@plainlicense.org",
    "url": "https://plainlicense.org"
  },
  "main": "../../content/licenses/source-available/elastic-2.0.md",
  "scripts": {
    "release": "bunx semantic-release"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "channel": "pre/rc",
        "name": "dev",
        "prerelease": true
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "release": "major",
              "type": "stable"
            },
            {
              "release": "minor",
              "type": "new"
            },
            {
              "release": "minor",
              "type": "subs"
            },
            {
              "release": "patch",
              "type": "admin"
            },
            {
              "release": false,
              "type": "bot"
            }
          ]
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/elastic-2.0.md",
          "changelogTitle": "Plain Elastic 2.0 Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "../changelogs/elastic-2.0.md"
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator"
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "label": "Plain Elastic License (Markdown)",
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.cm.md"
            },
            {
              "label": "Plain Elastic License (GitHub Markdown)",
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.gfm.md"
            },
            {
              "label": "Plain Elastic License (PDF)",
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.pdf"
            },
            {
              "label": "Plain Elastic License (Plaintext)",
              "path": "../../dist/exports/elastic-2.0/${nextRelease.version}/Plain-Elastic-${nextRelease.version}.txt"
            }
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:license-release",
    "@semantic-release/changelog": "catalog:license-release",
    "@semantic-release/commit-analyzer": "catalog:license-release",
    "@semantic-release/git": "catalog:license-release",
    "@semantic-release/github": "catalog:license-release",
    "@semantic-release/release-notes-generator": "catalog:license-release",
    "commitlint-plugin-selective-scope": "catalog:license-release",
    "semantic-release": "catalog:license-release",
    "semantic-release-cli": "catalog:license-release"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "",
      "onFail": "download"
    }
  }
}
