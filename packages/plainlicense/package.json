{
  "name": "plain-license-site",
  "version": "0.0.0-development",
  "private": true,
  "description": "Plain language versions of popular licenses",
  "author": {
    "name": "Adam Poulemanos",
    "email": "adam@plainlicense.org"
  },
  "type": "module",
  "main": "../../mkdocs.yml",
  "bin": {},
  "directories": {
    "build-source": "../../src/build",
    "ci": "../../.github",
    "mkdocs-hooks": "../../overrides/hooks",
    "site-assets": "../../src/assets",
    "site-css": "../../src/assets/stylesheets",
    "site-dir": "../../docs",
    "site-images": "../../src/assets/images",
    "site-theme": "../../overrides",
    "site-typescript-source": "../../src/assets/javascripts",
    "submodules": "../../external"
  },
  "scripts": {
    "deploy": "mkdocs gh-deploy",
    "release": "semantic-release"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "name": "dev",
        "prerelease": true,
        "channel": "pre/rc"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "stable",
              "release": "major"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "patch"
            },
            {
              "type": "new",
              "scope": "content",
              "release": "minor"
            },
            {
              "type": "new",
              "release": "patch"
            },
            {
              "scope": "scripts",
              "release": "patch"
            },
            {
              "type": "bot",
              "release": false
            },
            {
              "type": "chore",
              "release": false
            },
            {
              "scope": "infra",
              "release": false
            },
            {
              "scope": "deps",
              "release": false
            },
            {
              "scope": "blog",
              "release": false
            }
          ]
        }
      ],
      [
        "@semantic-release/github"
      ]
    ]
  },
  "devDependencies": {},
  "engines": {
    "node": "> 19"
  }
}
