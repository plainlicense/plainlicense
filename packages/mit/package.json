{
  "name": "plain-license-mit",
  "version": "0.2.1",
  "private": true,
  "description": "Plain language version of the MIT License",
  "main": "../../content/licenses/permissive/mit.md",
  "scripts": {
    "release": "semantic-release"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "name": "dev",
        "prerelease": true,
        "channel": "pre/rc"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "stable",
              "release": "major"
            },
            {
              "type": "new",
              "release": "minor"
            },
            {
              "type": "subs",
              "release": "minor"
            },
            {
              "type": "admin",
              "release": "patch"
            },
            {
              "type": "bot",
              "release": false
            }
          ]
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "../changelogs/mit.md",
          "changelogTitle": "Plain MIT Changelog"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "../changelogs/mit.md"
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator"
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "../../public/exports/mit/v${nextRelease.version}/MIT.md",
              "label": "Plain MIT License (Markdown)"
            },
            {
              "path": "../../public/exports/mit/v${nextRelease.version}/MIT.pdf",
              "label": "Plain MIT License (PDF)"
            },
            {
              "path": "../../public/exports/mit/v${nextRelease.version}/MIT.txt",
              "label": "Plain MIT License (Plaintext)"
            }
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1"
  }
}
