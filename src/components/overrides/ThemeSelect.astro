---
import type { Props } from "@astrojs/starlight/props";
// Wrap starlight-blog's ThemeSelect override (which includes blog navigation)
// but force dark mode and hide the theme toggle selector.
import BlogThemeSelect from "starlight-blog/overrides/ThemeSelect.astro";
---

<BlogThemeSelect {...Astro.props}><slot /></BlogThemeSelect>

<style is:global>
/* Hide the theme toggle — site is dark-only */
starlight-theme-select {
  display: none !important;
}
</style>

<script>
  document.documentElement.dataset.theme = 'dark';
  localStorage.setItem('starlight-theme', 'dark');
</script>
