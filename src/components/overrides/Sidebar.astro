---
import Default from "@astrojs/starlight/components/Sidebar.astro";
---

<div class="sidebar-wrapper">
  <div class="sidebar-filter">
    <input
      type="text"
      id="sidebar-search"
      placeholder="Filter licenses..."
      aria-label="Filter licenses"
      aria-describedby="sidebar-filter-status"
    />
    <div id="sidebar-filter-status" class="sr-only" aria-live="polite" aria-atomic="true"></div>
  </div>
  <Default {...Astro.props}>
    <slot />
  </Default>
</div>

<script>
const searchInput = document.getElementById(
  "sidebar-search",
) as HTMLInputElement;
const statusEl = document.getElementById("sidebar-filter-status");
if (searchInput) {
  let debounceTimer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    const sidebarItems = document.querySelectorAll("nav.sidebar-content li");
    let visibleCount = 0;

    sidebarItems.forEach((item) => {
      const el = item as HTMLElement;
      const text = el.textContent?.toLowerCase() || "";
      if (text.includes(query)) {
        el.style.display = "";
        el.removeAttribute("aria-hidden");
        visibleCount++;
      } else {
        el.style.display = "none";
        el.setAttribute("aria-hidden", "true");
      }
    });

    // Announce filter results to screen readers (debounced)
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      if (statusEl) {
        statusEl.textContent = query
          ? `${visibleCount} license${visibleCount !== 1 ? "s" : ""} found`
          : "Showing all licenses";
      }
    }, 300);
  });
}
</script>

<style>
.sidebar-wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
}
.sidebar-filter {
  padding: 1rem;
  border-bottom: 1px solid var(--sl-color-gray-5);
  position: sticky;
  top: 0;
  background: var(--sl-color-bg-sidebar);
  z-index: 10;
}
#sidebar-search {
  width: 100%;
  padding: 0.5rem;
  border-radius: 4px;
  border: 1px solid var(--sl-color-gray-5);
  background: var(--sl-color-gray-6);
  color: var(--sl-color-white);
  font-size: var(--sl-text-sm);
}
#sidebar-search:focus,
#sidebar-search:focus-visible {
  border-color: var(--sl-color-accent);
  outline: 2px solid var(--sl-color-accent);
  outline-offset: 1px;
}
</style>
