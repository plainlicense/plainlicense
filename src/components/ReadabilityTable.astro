---
/**
 * ReadabilityTable.astro
 * Shows a comparison of readability metrics across all published licenses.
 * Displays plain vs. original Gunning Fog scores and shame word counts.
 */
import { getLicenseSlug, getPublishedLicenses } from "../utils/collections";

const licenses = await getPublishedLicenses();

/** Map a Gunning Fog score to a plain-text grade label. */
function fogLabel(score: number): string {
  if (score <= 6) return "6th grade";
  if (score <= 8) return "8th grade";
  if (score <= 10) return "10th grade";
  if (score <= 12) return "High school";
  if (score <= 14) return "College";
  return "Post-graduate";
}

/** Return a CSS class based on readability level (lower = better). */
function fogClass(score: number): string {
  if (score <= 8) return "level-good";
  if (score <= 12) return "level-fair";
  return "level-hard";
}

interface LicenseRow {
  name: string;
  /** Canonical path segment as returned by getLicenseSlug(), e.g. permissive/mit */
  slug: string;
  originalFog: number | undefined;
  plainFog: number | undefined;
  shameCount: number | undefined;
  improvement: number | undefined;
}

const rows: LicenseRow[] = licenses
  .filter((l) => l.data.original)
  .map((l) => {
    const originalFog = l.data.original?.original_gunning_fog;
    const plainFog = l.data.plain_gunning_fog;
    const improvement =
      originalFog !== undefined && plainFog !== undefined
        ? parseFloat((originalFog - plainFog).toFixed(2))
        : undefined;
    return {
      name: l.data.plain_name,
      slug: getLicenseSlug(l),
      originalFog,
      plainFog,
      shameCount: l.data.shame_words_count,
      improvement,
    };
  })
  .sort((a, b) => (b.improvement ?? 0) - (a.improvement ?? 0));
---

{rows.length > 0 ? (
  <div class="readability-table-wrapper" role="region" aria-label="Readability comparison table" tabindex="0">
    <table class="readability-table">
      <caption>
        Readability comparison — Gunning Fog Index (lower = easier to read)
      </caption>
      <thead>
        <tr>
          <th scope="col">License</th>
          <th scope="col" class="num-col">Original fog</th>
          <th scope="col" class="num-col">Plain fog</th>
          <th scope="col" class="num-col">Improvement</th>
          <th scope="col" class="num-col">Shame terms remaining</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td>
              <a href={`/licenses/${row.slug}/`}>{row.name}</a>
            </td>
            <td class={`num-col ${row.originalFog !== undefined ? fogClass(row.originalFog) : ""}`}>
              {row.originalFog !== undefined
                ? `${row.originalFog} (${fogLabel(row.originalFog)})`
                : "—"}
            </td>
            <td class={`num-col ${row.plainFog !== undefined ? fogClass(row.plainFog) : ""}`}>
              {row.plainFog !== undefined
                ? `${row.plainFog} (${fogLabel(row.plainFog)})`
                : "—"}
            </td>
            <td class={`num-col ${row.improvement !== undefined && row.improvement > 0 ? "improvement-positive" : ""}`}>
              {row.improvement !== undefined
                ? row.improvement > 0
                  ? `↓ ${row.improvement} grades`
                  : row.improvement === 0
                    ? "No change"
                    : `↑ ${Math.abs(row.improvement)} grades`
                : "—"}
            </td>
            <td class="num-col">
              {row.shameCount !== undefined ? row.shameCount : "—"}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
) : (
  <p><em>No readability data available yet.</em></p>
)}

<style>
.readability-table-wrapper {
  overflow-x: auto;
  margin: 1.5rem 0;
}

.readability-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--sl-text-sm);
}

.readability-table caption {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
  margin-bottom: 0.5rem;
  text-align: left;
}

.readability-table th,
.readability-table td {
  padding: 0.5rem 0.75rem;
  border: 1px solid var(--sl-color-gray-5);
  text-align: left;
  vertical-align: middle;
}

.readability-table th {
  background: var(--sl-color-gray-6);
  font-weight: 600;
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-2);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.readability-table tbody tr:hover {
  background: var(--sl-color-gray-7, rgba(255,255,255,0.03));
}

.num-col {
  text-align: right;
  white-space: nowrap;
}

.level-good {
  color: var(--sl-color-green);
}

.level-fair {
  color: var(--sl-color-yellow);
}

.level-hard {
  color: var(--sl-color-red);
}

.improvement-positive {
  color: var(--sl-color-green);
  font-weight: 600;
}
</style>
