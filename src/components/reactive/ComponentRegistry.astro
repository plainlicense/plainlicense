---
import ComparisonTable from "./ComparisonTable.astro";
import FAQ from "./FAQ.astro";
import LicenseFinderWrapper from "./LicenseFinderWrapper.astro";

interface Props {
  type: string;
  id?: string;
  props?: Record<string, unknown>;
  licenseData?: unknown;
}

const { type, id, props = {}, licenseData } = Astro.props;

// Process props to parse JSON strings if they look like JSON
const processedProps = { ...props };

// Data flow enhancement: if props are missing data, try to pull from license frontmatter
if (type === "faq" && !processedProps.items && licenseData?.faq) {
  processedProps.items = licenseData.faq[id || "default"];
} else if (type === "table" && !processedProps.data && licenseData?.tables) {
  processedProps.data = licenseData.tables[id || "default"];
}

for (const key in processedProps) {
  const val = processedProps[key];
  if (
    typeof val === "string" &&
    (val.trim().startsWith("[") || val.trim().startsWith("{"))
  ) {
    try {
      processedProps[key] = JSON.parse(val);
    } catch (e) {
      // Keep as string if parsing fails
      console.warn(`Failed to parse JSON for prop ${key}: ${val}`, e);
    }
  }
}
---

{type === 'faq' && <FAQ id={id} {...processedProps} />}
{type === 'table' && <ComparisonTable id={id} {...processedProps} />}
{type === 'tree' && <LicenseFinderWrapper id={id} />}

{!['faq', 'table', 'tree'].includes(type) && (
  <div class="error">Unknown component type: {type}</div>
)}
