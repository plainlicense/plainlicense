---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  id?: string;
  items?: FAQItem[];
}

const { id, items = [] } = Astro.props;

// Mock items if none provided for prototype
const displayItems =
  items.length > 0
    ? items
    : [
        {
          question: "Is this license OSI approved?",
          answer: "Yes, the MIT license is OSI approved.",
        },
        {
          question: "Can I use this for commercial projects?",
          answer: "Yes! You can use this license for commercial projects.",
        },
      ];
---

<div class="faq-component" id={id}>
  {
    displayItems.map((item) => (
      <details class="faq-item">
        <summary>{item.question}</summary>
        <div class="faq-answer">
          <p>{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  .faq-component {
    margin: 2rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
  }
  .faq-item {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .faq-item:last-child {
    border-bottom: none;
  }
  summary {
    padding: 1rem;
    background: var(--sl-color-gray-6);
    cursor: pointer;
    font-weight: bold;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::after {
    content: "+";
    font-size: 1.2rem;
    color: var(--accent-purple);
  }
  details[open] summary::after {
    content: "−";
  }
  .faq-answer {
    padding: 1rem;
    background: var(--sl-color-black);
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }
  .faq-answer p {
    margin: 0;
  }
</style>
