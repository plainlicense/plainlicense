---
interface TableData {
  headers: string[];
  rows: string[][];
}

interface Props {
  id?: string;
  title?: string;
  data?: TableData;
}

const { id, title, data } = Astro.props;

// Default data for the prototype if none provided
const tableData: TableData = data || {
  headers: ["Feature", "MIT", "GPL v3", "Apache 2.0"],
  rows: [
    ["Commercial Use", "yes", "yes", "yes"],
    ["Modification", "yes", "yes", "yes"],
    ["Distribution", "yes", "yes", "yes"],
    ["Sublicensing", "yes", "no", "yes"],
    ["Patent Grant", "no", "yes", "yes"],
  ],
};

// Map semantic values to accessible display
function renderCellValue(value: string) {
  if (value === "yes") return { symbol: "✅", label: "Yes" };
  if (value === "no") return { symbol: "❌", label: "No" };
  if (value === "partial") return { symbol: "⚠️", label: "Partial" };
  return { symbol: value, label: value };
}
---

<div class="table-container" id={id}>
  {title && <h3>{title}</h3>}
  <div class="responsive-table">
    <table aria-label={title || "License feature comparison"}>
      <thead>
        <tr>
          {
            tableData.headers.map((header: string) => (
              // @ts-expect-error - It doesn't like the the key attribute
              <th scope="col" key={header}>
                {header}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          tableData.rows.map((row: string[]) => (
            // @ts-expect-error - It doesn't like the the key attribute
            <tr key={row[0]}>
              {row.map((cell: string, index: number) => {
                if (index === 0) {
                  return (
                    // @ts-expect-error - It doesn't like the the key attribute
                    <th scope="row" class="feature-label" key={cell}>
                      {cell}
                    </th>
                  );
                }
                const colHeader = tableData.headers[index] ?? `col-${index}`;
                const { symbol, label } = renderCellValue(cell);
                const isSymbol = symbol !== cell;
                return (
                  // @ts-expect-error - It doesn't like the the key attribute
                  <td class="feature-value" key={`${row[0]}-${colHeader}`}>
                    {isSymbol ? (
                      <>
                        <span aria-hidden="true">{symbol}</span>
                        <span class="sr-only">{label}</span>
                      </>
                    ) : (
                      cell
                    )}
                  </td>
                );
              })}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>

<style>
  .table-container {
    margin: 2rem 0;
  }
  .responsive-table {
    overflow-x: auto;
    border: 1px solid #333;
    border-radius: 8px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    background: #1a1c23;
    font-size: 0.9rem;
  }
  th {
    background: #252833;
    text-align: left;
    padding: 1rem;
    border-bottom: 2px solid #333;
    color: #883aea;
  }
  td {
    padding: 1rem;
    border-bottom: 1px solid #333;
  }
  tr:last-child td {
    border-bottom: none;
  }
  .feature-label {
    font-weight: bold;
    background: #1e2129;
    width: 30%;
  }
  .feature-value {
    text-align: center;
  }
  tr:hover {
    background: #252833;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
