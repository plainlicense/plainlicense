---
/**
 * A toggle component to enable/disable interactive comparison mode.
 * Persists preference in localStorage.
 * Shown in an unavailable/disabled state when no mapping data is available for this license.
 */
interface Props {
  hasMapping?: boolean;
}

const { hasMapping = false } = Astro.props;
---

{hasMapping ? (
    <div class="comparison-toggle-container">
      <button
        id="comparison-toggle"
        type="button"
        class="toggle-btn"
        aria-pressed="false"
      >
        <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="toggle-text">Enable Interactive Comparison</span>
      </button>
      <p class="toggle-hint">
        Hover or focus on sections to see connections to the original
      </p>
    </div>
  ) : (
    <div class="comparison-toggle-container comparison-toggle--unavailable">
      <button
        type="button"
        class="toggle-btn toggle-btn--disabled"
        disabled
        aria-disabled="true"
      >
        <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="toggle-text">Side-by-side comparison coming soon</span>
      </button>
      <p class="toggle-hint">
        Interactive comparison is not yet available for this license
      </p>
    </div>
  )}

<script>
const toggleBtn = document.getElementById(
  "comparison-toggle",
) as HTMLButtonElement | null;
const container = document.querySelector(".license-container") as HTMLElement;
const STORAGE_KEY = "pl-comparison-mode";

if (toggleBtn) {
  const toggleText = toggleBtn.querySelector(
    ".toggle-text",
  ) as HTMLSpanElement | null;

  function updateUI(isActive: boolean) {
    if (isActive) {
      container?.classList.add("comparison-active");
      toggleBtn?.setAttribute("aria-pressed", "true");
      toggleBtn?.classList.add("active");
      if (toggleText) {
        toggleText.textContent = "Disable Interactive Comparison";
      }
    } else {
      container?.classList.remove("comparison-active");
      toggleBtn?.setAttribute("aria-pressed", "false");
      toggleBtn?.classList.remove("active");
      if (toggleText) {
        toggleText.textContent = "Enable Interactive Comparison";
      }
    }
  }

  // Load preference
  const savedPreference = localStorage.getItem(STORAGE_KEY) === "true";
  updateUI(savedPreference);

  toggleBtn.addEventListener("click", () => {
    const isNowActive = !container.classList.contains("comparison-active");
    localStorage.setItem(STORAGE_KEY, String(isNowActive));
    updateUI(isNowActive);
  });
}
</script>

<style>
.comparison-toggle-container {
  margin-top: 2.5rem;
  padding: 1rem 1.25rem;
  background: var(--bg-surface, var(--sl-color-gray-6));
  border-radius: 0.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  border: 1px solid var(--bg-border, var(--sl-color-gray-5));
  flex-wrap: wrap;
}
.toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  background: transparent;
  color: var(--sl-color-white);
  border: 1px solid var(--bg-border, var(--sl-color-gray-5));
  padding: 0.4rem 1rem;
  border-radius: 6px;
  cursor: pointer;
  font-weight: 500;
  font-size: 0.85rem;
  transition: all 0.15s;
}
.toggle-btn:hover {
  border-color: var(--sl-color-accent);
  color: var(--sl-color-accent);
  background: transparent;
}
.toggle-btn.active {
  background: rgba(var(--emerald-rgb), 0.1);
  border-color: var(--sl-color-accent);
  color: var(--sl-color-accent);
}
.toggle-btn--disabled {
  border-color: var(--sl-color-gray-4);
  color: var(--sl-color-gray-3);
  cursor: not-allowed;
  opacity: 0.5;
}
.toggle-btn--disabled:hover {
  background: transparent;
  color: var(--sl-color-gray-3);
  border-color: var(--sl-color-gray-4);
}
.toggle-hint {
  font-size: 0.8rem;
  color: var(--sl-color-gray-3);
  margin: 0;
}
.toggle-icon {
  width: 0.9rem;
  height: 0.9rem;
  flex-shrink: 0;
}
</style>
