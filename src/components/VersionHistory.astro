---
import type { CollectionEntry } from "astro:content";
import fs from "node:fs/promises";
import path from "node:path";
import { FAMILY_ORDER } from "../../data/license-families/index";

interface Props {
  license: CollectionEntry<"licenses">;
}

const { license } = Astro.props;
const { license_family, spdx_id } = license.data;

// Look for versions.json in the content directory
const category = license_family || FAMILY_ORDER[1];
const slug =
  spdx_id?.toLowerCase() || license.id.split("/").pop()?.replace(/\.md$/, "");
const versionsPath = path.resolve(
  "content/licenses",
  category,
  `${slug}.versions.json`,
);
let versions = [];

try {
  const content = await fs.readFile(versionsPath, "utf8");
  versions = JSON.parse(content);
} catch (e) {
  // Fallback to current version if versions.json doesn't exist
  versions = [
    {
      version: license.data.plain_version,
      date: "unknown",
      changelog: "Initial release",
    },
  ];
}

function getDatetime(date: string): string | undefined {
  return /^\d{4}-\d{2}-\d{2}/.test(date) ? date : undefined;
}
---

<section class="version-history" aria-labelledby="version-history-heading">
  <h3 id="version-history-heading">Version History</h3>
  <div class="timeline">
    {versions.map(
        (v: { version: string; date: string; changelog: string }) => (
          // @ts-ignore
          <div key={v.version} class="version-item">
            <div class="version-badge">v{v.version}</div>
            <div class="version-details">
              <time datetime={getDatetime(v.date)}>{v.date}</time>
              <p>{v.changelog}</p>
            </div>
          </div>
        ),
      )}
  </div>
</section>

<style>
.version-history {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--sl-color-gray-5);
}
.timeline {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-top: 1.5rem;
}
.version-item {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
}
.version-badge {
  background: var(--sl-color-accent);
  color: var(--sl-color-black);
  padding: 0.25rem 0.75rem;
  border-radius: 99px;
  font-weight: bold;
  font-size: var(--sl-text-xs);
  min-width: 60px;
  text-align: center;
}
.version-details time {
  display: block;
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
  margin-bottom: 0.25rem;
}
.version-details p {
  margin: 0;
  font-size: var(--sl-text-sm);
  color: var(--sl-color-gray-2);
}
</style>
