---
import type { CollectionEntry } from 'astro:content';
import fs from 'node:fs/promises';
import path from 'node:path';

interface Props {
  license: CollectionEntry<'licenses'>;
}

const { license } = Astro.props;
const { license_type, spdx_id } = license.data;

// Look for versions.json in the content directory
const category = license_type || 'permissive';
const slug = spdx_id?.toLowerCase() || license.id.split('/').pop()?.replace(/\.md$/, '');
const versionsPath = path.resolve('content/licenses', category, `${slug}.versions.json`);
let versions = [];

try {
  const content = await fs.readFile(versionsPath, 'utf8');
  versions = JSON.parse(content);
} catch (e) {
  // Fallback to current version if versions.json doesn't exist
  versions = [{
    version: license.data.version,
    date: license.data.last_modified || 'unknown',
    changelog: 'Initial release'
  }];
}
---

<section class="version-history">
  <h3>Version History</h3>
  <div class="timeline">
    {versions.map((v: any) => (
      <div class="version-item">
        <div class="version-badge">v{v.version}</div>
        <div class="version-details">
          <time>{v.date}</time>
          <p>{v.changelog}</p>
          <div class="version-downloads">
            <span class="download-label">Downloads:</span>
            <a href={`/exports/${slug}/v${v.version}/${spdx_id}.pdf`} class="download-link">PDF</a>
            <a href={`/exports/${slug}/v${v.version}/${spdx_id}.txt`} class="download-link">TXT</a>
            <a href={`/exports/${slug}/v${v.version}/${spdx_id}.gfm.md`} class="download-link">MD</a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .version-history {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .version-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .version-badge {
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-weight: bold;
    font-size: var(--sl-text-xs);
    min-width: 60px;
    text-align: center;
  }
  .version-details time {
    display: block;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    margin-bottom: 0.25rem;
  }
  .version-details p {
    margin: 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
  }
  .version-downloads {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .download-label {
    font-size: 0.75rem;
    color: var(--sl-color-gray-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .download-link {
    font-size: 0.75rem;
    color: var(--sl-color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .download-link:hover {
    border-bottom-color: var(--sl-color-accent);
  }
</style>
