---
/**
 * LicenseLayout: Orchestrates the seven-zone anatomy for every plain license.
 *
 * Zone 1: Identity & orientation  — always visible
 * Zone 2: What you can do         — always visible
 * Zone 3: What you must do        — visible if conditions exist
 * Zone 4: How to give credit      — visible if attribution_required
 * ── fold line ──────────────────────────────────────────────────────────
 * Zone 5: What you cannot do      — always visible (restrictions matter)
 * Zone 6: Standard protections    — collapsed
 * Zone 7: Legal interpretation    — collapsed
 */
import type { LicenseEntryT } from "../../_types/licenses";
import { getFamilyData } from "../../data/license-families/index";
import { getLicenseSlug, getPublishedLicenses } from "../../utils/collections";
import FAQ from "../reactive/FAQ.astro";
import CompareWith from "./CompareWith.astro";
import TermDefinitions from "./TermDefinitions.astro";
import ZoneConditions from "./zones/ZoneConditions.astro";
import ZoneCredit from "./zones/ZoneCredit.astro";
import ZoneIdentity from "./zones/ZoneIdentity.astro";
import ZoneInterpretation from "./zones/ZoneInterpretation.astro";
import ZonePermissions from "./zones/ZonePermissions.astro";
import ZoneProtections from "./zones/ZoneProtections.astro";
import ZoneRestrictions from "./zones/ZoneRestrictions.astro";

interface Props {
  license: LicenseEntryT;
}

const { license } = Astro.props;
const { data } = license;

const family = getFamilyData(data.license_family);

const permissions = data.original?.permissions ?? [];
const conditions = data.original?.conditions ?? [];
// Filter out warranty/liability from limitations — they are licensor protections (Zone 6),
// not user restrictions (Zone 5). Only trademark-use and patent-use are true restrictions.
const PROTECTION_TAGS = new Set(["liability", "warranty"]);
const limitations = (data.original?.limitations ?? []).filter(
  (tag) => !PROTECTION_TAGS.has(tag),
);

// Resolve compare_to entries to slugs and names
const allLicenses = await getPublishedLicenses();
const spdxLookup = new Map(
  allLicenses.flatMap((l) => {
    const spdxId = l.data.spdx_id;
    const slug = getLicenseSlug(l);
    if (!spdxId || !slug) return [];

    return [
      [
        spdxId,
        {
          slug,
          name: l.data.plain_name ?? spdxId,
          family: l.data.license_family,
        },
      ],
    ] as const;
  }),
);
const compareEntries = (data.compare_to ?? []).flatMap((c) => {
  if (!c.spdx_id) return [];

  const match = spdxLookup.get(c.spdx_id);
  if (!match?.slug) return [];

  return [
    {
      spdx_id: c.spdx_id,
      contrast: c.contrast ?? "",
      slug: match.slug,
      name: match.name,
      family: match.family ?? data.license_family,
    },
  ];
});
---

<article
  class="plain-license"
  data-family={data.license_family}
  data-spdx={data.spdx_id}
  aria-label={data.plain_name}
>
  <!-- Zone 1: Identity & orientation -->
  <ZoneIdentity
    plain_name={data.plain_name}
    license_family={data.license_family}
    description={data.description ?? ""}
    tldr={data.tldr ?? [""]}
    is_dedication={data.is_dedication}
    original={data.original}
    maker_pitch={data.maker_pitch}
  />

  <!-- Zone 2: What you can do -->
  <ZonePermissions permissions={permissions} />

  <!-- Zone 3: What you must do -->
  {conditions.length > 0 && <ZoneConditions conditions={conditions} />}

  <!-- Zone 4: How to give credit -->
  {
    data.attribution_required && (
      <ZoneCredit plain_name={data.plain_name} original={data.original} />
    )
  }

  <!-- Zone 5: What you cannot do -->
  {
    (limitations.length > 0 ||
      (data.commercial_restrictions ?? []).length > 0) && (
      <ZoneRestrictions
        limitations={limitations}
        commercialRestrictions={data.commercial_restrictions ?? []}
        aboveFold={true}
      />
    )
  }

  <!-- Compare with similar licenses -->
  {compareEntries.length > 0 && <CompareWith entries={compareEntries} />}

  <!-- Below-fold divider -->
  <div class="fold-divider" aria-hidden="true">
    <span class="fold-label">Less commonly needed</span>
  </div>

  <!-- Zone 6: Standard protections -->
  <ZoneProtections protections={family.protections} />

  <!-- Extended term definitions (only for licenses with unique terms) -->
  {
    (data.defined_terms ?? []).length > 0 && (
      <TermDefinitions terms={data.defined_terms} />
    )
  }

  <!-- Zone 7: Legal interpretation -->
  <ZoneInterpretation
    plain_name={data.plain_name}
    license_family={data.license_family}
    is_dedication={data.is_dedication}
    original={data.original}
  />

  <!-- FAQ (from frontmatter) -->
  {(data.faq ?? []).length > 0 && <FAQ items={data.faq} />}

  <!-- Optional slot for exceptional MDX body content -->
  <slot name="outro" />
</article>

<style>
  .plain-license {
    container-type: inline-size;
  }

  .fold-divider {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 3rem 0 2rem;
    padding: 0.6rem 0;
    color: var(--sl-color-gray-3);
  }

  .fold-divider::before,
  .fold-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--sl-color-gray-4),
      var(--sl-color-gray-5),
      transparent
    );
  }

  .fold-label {
    font-size: var(--sl-text-2xs, 0.6875rem);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 1rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 99px;
  }
</style>
