---
/**
 * Compact readability stats card for the reference section.
 * Shows plain vs original Gunning Fog comparison when available.
 */
import { ICONS } from "./icons";

interface Props {
  plain_gunning_fog?: number;
  original_gunning_fog?: number;
  shame_words_count?: number;
}

const { plain_gunning_fog, original_gunning_fog, shame_words_count } = Astro.props;

function readabilityLevel(score: number): string {
  if (score <= 6) return "6th grade";
  if (score <= 8) return "8th grade";
  if (score <= 10) return "10th grade";
  if (score <= 12) return "High school";
  if (score <= 14) return "College";
  return "Post-graduate";
}

const hasData = plain_gunning_fog !== undefined || shame_words_count !== undefined;
const hasComparison = plain_gunning_fog !== undefined && original_gunning_fog !== undefined;
const improvement = hasComparison
  ? parseFloat((original_gunning_fog! - plain_gunning_fog!).toFixed(1))
  : undefined;
---

{hasData && (
  <section class="readability-card" aria-label="Readability">
    <h3 class="readability-heading">
      <svg class="readability-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS["bar-chart"]} />
      Readability
    </h3>

    {plain_gunning_fog !== undefined && (
      <div class="stat-row">
        <span class="stat-label">Reading level</span>
        <span class="stat-value plain-value">
          {plain_gunning_fog}
          <small>({readabilityLevel(plain_gunning_fog)})</small>
        </span>
      </div>
    )}

    {hasComparison && (
      <div class="stat-row">
        <span class="stat-label">Original</span>
        <span class="stat-value original-value">
          {original_gunning_fog}
          <small>({readabilityLevel(original_gunning_fog!)})</small>
        </span>
      </div>
    )}

    {improvement !== undefined && improvement > 0 && (
      <div class="improvement">
        {improvement} grades easier to read
      </div>
    )}

    {shame_words_count !== undefined && (
      <div class="stat-row">
        <span class="stat-label">Legal jargon remaining</span>
        <span class={`stat-value ${shame_words_count === 0 ? "shame-zero" : ""}`}>{shame_words_count}</span>
      </div>
    )}

    <p class="readability-note">
      Measured with the Gunning Fog Index — lower scores mean easier reading.
    </p>
  </section>
)}

<style>
.readability-card {
  background: var(--sl-color-gray-6);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  margin-bottom: 1rem;
  max-width: 28rem;
}

.readability-heading {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: var(--sl-text-sm);
  font-weight: 600;
  color: var(--sl-color-gray-1);
  margin: 0 0 0.75rem 0;
}

.readability-icon {
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
  color: var(--cat-color, var(--sl-color-accent));
}

.stat-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  padding: 0.3rem 0;
}

.stat-label {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
}

.stat-value {
  font-weight: 700;
  font-size: var(--sl-text-base);
  color: var(--sl-color-gray-1);
}

.stat-value small {
  font-size: var(--sl-text-xs);
  font-weight: normal;
  color: var(--sl-color-gray-3);
}

.plain-value {
  color: var(--cat-color, var(--sl-color-accent));
}

.original-value {
  color: var(--sl-color-gray-2);
}

.shame-zero {
  color: var(--cat-color, var(--sl-color-accent));
}

.improvement {
  text-align: center;
  padding: 0.35rem 0.75rem;
  margin: 0.4rem 0;
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  border-radius: 6px;
  font-size: var(--sl-text-xs);
  font-weight: 600;
  color: var(--cat-color, var(--sl-color-accent));
}

.readability-note {
  font-size: var(--sl-text-2xs, 0.6875rem);
  color: var(--sl-color-gray-4);
  margin: 0.5rem 0 0 0;
  line-height: 1.4;
}
</style>
