---
/**
 * Compact readability stats card for the reference section.
 * Shows plain vs original Gunning Fog comparison when available.
 */
import { ICONS } from "./icons";

interface Props {
  plain_gunning_fog?: number;
  original_gunning_fog?: number;
  shame_words_count?: number;
}

const { plain_gunning_fog, original_gunning_fog, shame_words_count } = Astro.props;

function readabilityLevel(score: number): string {
  if (score <= 6) return "6th grade";
  if (score <= 8) return "8th grade";
  if (score <= 10) return "10th grade";
  if (score <= 12) return "High school";
  if (score <= 14) return "College";
  return "Post-graduate";
}

const hasData = plain_gunning_fog !== undefined || shame_words_count !== undefined;
const hasComparison = plain_gunning_fog !== undefined && original_gunning_fog !== undefined;
const improvement = hasComparison
  ? parseFloat((original_gunning_fog! - plain_gunning_fog!).toFixed(1))
  : undefined;
---

{hasData && (
  <details class="readability-sidebar">
    <summary class="readability-summary">
      <svg class="readability-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS["bar-chart"]} />
      <span class="readability-label">Readability</span>
      {plain_gunning_fog !== undefined && (
        <span class="readability-score">{plain_gunning_fog} ({readabilityLevel(plain_gunning_fog)})</span>
      )}
      <svg class="summary-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS["chevron-down"]} />
    </summary>
    <div class="readability-body">
      {hasComparison && (
        <div class="comparison-row">
          <div class="comparison-item">
            <span class="comparison-label">Plain version</span>
            <span class="comparison-value plain-value">{plain_gunning_fog} <small>({readabilityLevel(plain_gunning_fog!)})</small></span>
          </div>
          <div class="comparison-item">
            <span class="comparison-label">Original</span>
            <span class="comparison-value original-value">{original_gunning_fog} <small>({readabilityLevel(original_gunning_fog!)})</small></span>
          </div>
          {improvement !== undefined && improvement > 0 && (
            <div class="improvement">
              <span class="improvement-value">{improvement} grades easier</span>
            </div>
          )}
        </div>
      )}
      {shame_words_count !== undefined && (
        <div class="shame-row">
          <span class="shame-label">Legal jargon remaining</span>
          <span class={`shame-value ${shame_words_count === 0 ? "shame-zero" : ""}`}>{shame_words_count}</span>
        </div>
      )}
      <p class="readability-note">
        Measured with the Gunning Fog Index — lower scores mean easier reading.
      </p>
    </div>
  </details>
)}

<style>
.readability-sidebar {
  background: var(--sl-color-gray-6);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 8px;
  margin-bottom: 1rem;
  overflow: hidden;
}

.readability-summary {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  cursor: pointer;
  list-style: none;
  user-select: none;
  font-size: var(--sl-text-sm);
  color: var(--sl-color-gray-1);
  font-weight: 600;
}

.readability-summary::-webkit-details-marker {
  display: none;
}

.readability-summary:hover {
  background: var(--sl-color-gray-5);
}

.readability-icon {
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
  color: var(--cat-color, var(--sl-color-accent));
}

.readability-label {
  flex: 0;
  white-space: nowrap;
}

.readability-score {
  font-weight: normal;
  color: var(--sl-color-gray-3);
  font-size: var(--sl-text-xs);
  margin-left: auto;
}

.summary-arrow {
  width: 0.85rem;
  height: 0.85rem;
  color: var(--sl-color-gray-3);
  transition: transform 0.2s;
  flex-shrink: 0;
}

details[open] .summary-arrow {
  transform: rotate(180deg);
}

.readability-body {
  padding: 0 1rem 1rem;
  border-top: 1px solid var(--sl-color-gray-5);
}

.comparison-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-top: 0.75rem;
  margin-bottom: 0.75rem;
}

.comparison-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.comparison-label {
  font-size: var(--sl-text-2xs, 0.6875rem);
  color: var(--sl-color-gray-4);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.comparison-value {
  font-size: var(--sl-text-lg);
  font-weight: 700;
}

.comparison-value small {
  font-size: var(--sl-text-xs);
  font-weight: normal;
  color: var(--sl-color-gray-3);
}

.plain-value {
  color: var(--cat-color, var(--sl-color-accent));
}

.original-value {
  color: var(--sl-color-gray-2);
}

.improvement {
  grid-column: 1 / -1;
  text-align: center;
  padding: 0.35rem 0.75rem;
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  border-radius: 6px;
}

.improvement-value {
  font-size: var(--sl-text-xs);
  font-weight: 600;
  color: var(--cat-color, var(--sl-color-accent));
}

.shame-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem 0;
  font-size: var(--sl-text-sm);
  color: var(--sl-color-gray-2);
}

.shame-label {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
}

.shame-value {
  font-weight: 700;
  font-size: var(--sl-text-base);
}

.shame-zero {
  color: var(--cat-color, var(--sl-color-accent));
}

.readability-note {
  font-size: var(--sl-text-2xs, 0.6875rem);
  color: var(--sl-color-gray-4);
  margin: 0.5rem 0 0 0;
  line-height: 1.4;
}
</style>
