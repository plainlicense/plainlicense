---
/**
 * Zone 4: How to give credit
 * Only renders when attribution_required is true.
 * Pulls examples, not-required list, and extra notes from frontmatter `credit`.
 * Falls back to sensible defaults when frontmatter fields are absent.
 */

interface CreditExample {
  context: string;
  code: string;
}

interface CreditData {
  examples?: CreditExample[];
  not_required?: string[];
  extra?: string;
}

interface Props {
  plain_name: string;
  credit?: CreditData;
}

import { marked } from "marked";
import { ICONS } from "../icons";

const { plain_name, credit } = Astro.props;

const defaultExamples: CreditExample[] = [
  {
    context: "In a source file header",
    code: `// Copyright (c) 2025 Your Name. ${plain_name}.\n// Keep the copyright notice and the ${plain_name} with any copy you share.`,
  },
  {
    context: "In a README or document",
    code: `This project is licensed under the ${plain_name}.\nSee LICENSE for details.`,
  },
  {
    context: "On a website or app",
    code: `© 2025 Your Name — ${plain_name}`,
  },
];

const defaultNotRequired = [
  "Use a specific format or location",
  "Ask for permission before using the work",
  "Include the full license text everywhere you use the work",
  "Use our exact wording — just keep the copyright notice and a reference to the license",
];

const examples = credit?.examples?.length ? credit.examples : defaultExamples;
const notRequired = credit?.not_required?.length
  ? credit.not_required
  : defaultNotRequired;
const extraHtml = credit?.extra
  ? marked.parse(credit.extra, { async: false })
  : "";
---

<section class="zone zone-credit" aria-label="How to give credit">
  <h2 class="zone-heading">
    <svg
      class="zone-heading-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={ICONS.copyright}
    />
    How to give credit
  </h2>

  <p class="zone-intro">
    When you share this work, you must include the copyright notice and a
    reference to this license. Here is what that looks like:
  </p>

  <div class="attribution-template">
    <p class="template-label">
      Attribution template — replace the bracketed text with your own details:
    </p>
    <code class="template-code">
      [Work name] &copy; [Year] [Creator name].{" "}
      {plain_name}.
    </code>
  </div>

  <div class="examples">
    <h3 class="examples-heading">Where to put it</h3>
    <div class="example-list">
      {
        examples.map((ex) => (
          <div class="example-item">
            <div class="example-context">{ex.context}</div>
            <pre class="example-code">
              <code>{ex.code}</code>
            </pre>
          </div>
        ))
      }
    </div>
  </div>

  {extraHtml && <div class="extra-notes" set:html={extraHtml} />}

  <div class="not-required-box">
    <p class="not-required-heading">
      <svg
        class="not-required-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={ICONS.info}
      />
      <strong>You do not need to:</strong>
    </p>
    <ul class="not-required-list">
      {notRequired.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>

<style>
  .zone-credit {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    border-radius: 12px;
    border-left: 3px solid rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
    background: linear-gradient(
      135deg,
      rgba(var(--cat-color-rgb, 21, 219, 149), 0.03),
      transparent
    );
  }

  .zone-heading {
    font-size: var(--sl-text-xl);
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--sl-color-white);
  }

  .zone-heading-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .zone-intro {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .attribution-template {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .template-label {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem 0;
  }

  .template-code {
    font-family: var(--sl-font-mono, monospace);
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-1);
    display: block;
    word-break: break-word;
  }

  .template-code a {
    color: var(--sl-color-accent);
  }

  .examples-heading {
    font-size: var(--sl-text-base);
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    color: var(--sl-color-gray-1);
  }

  .example-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .example-item {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
  }

  .example-context {
    background: var(--sl-color-gray-5);
    padding: 0.35rem 0.75rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .example-code {
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .example-code code {
    font-family: var(--sl-font-mono, monospace);
  }

  .extra-notes {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  .extra-notes :global(a) {
    color: var(--sl-color-accent);
  }

  .not-required-box {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .not-required-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.5rem 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-1);
  }

  .not-required-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--sl-color-gray-3);
  }

  .not-required-list {
    margin: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .not-required-list li {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }
</style>
