---
/**
 * A responsive modal for displaying original license text on mobile.
 */
---

<div id="comparison-modal" class="modal-overlay" aria-hidden="true">
  <div class="modal-content" role="dialog" aria-labelledby="modal-title">
    <div class="modal-header">
      <h3 id="modal-title">Original License Text</h3>
      <button id="close-modal" class="close-btn" aria-label="Close modal">&times;</button>
    </div>
    <div id="modal-body" class="modal-body prose">
      <!-- Content injected by MappingViewer.ts -->
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    display: none;
    justify-content: center;
    align-items: flex-end; /* Bottom sheet feel on mobile */
    z-index: 2000;
    padding: 1rem;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal-content {
    background: var(--sl-color-gray-6);
    width: 100%;
    max-width: 600px;
    max-height: 80vh;
    border-radius: 1rem 1rem 0 0;
    display: flex;
    flex-direction: column;
    box-shadow: 0 -10px 25px rgba(0, 0, 0, 0.5);
    animation: slideUp 0.3s ease-out;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .modal-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--sl-color-accent);
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--sl-color-white);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.5rem;
  }

  .modal-body {
    padding: 1.5rem;
    overflow-y: auto;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .modal-overlay {
      align-items: center;
    }
    .modal-content {
      border-radius: 1rem;
      animation: fadeIn 0.3s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
  }
</style>

<script>
  const modal = document.getElementById('comparison-modal');
  const closeBtn = document.getElementById('close-modal');

  function closeModal() {
    modal?.classList.remove('open');
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeModal);
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Close on Escape key
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('open')) {
      closeModal();
    }
  });
</script>
