---
/**
 * Inline footnote tooltip component for MDX pages.
 * Renders the same markup as the markdown post-processor (src/utils/footnotes.ts).
 * Styles and behavior come from the shared footnotes.css and FootnoteScript.astro.
 */
interface Props {
  note: string;
}

const { note } = Astro.props;
const id = `fn-${Math.random().toString(36).slice(2, 8)}`;
---

<span class="fn-wrap">
  <button
    class="fn-marker"
    type="button"
    aria-expanded="false"
    aria-describedby={id}
  >*</button>
  <span class="fn-tooltip" id={id} role="tooltip" aria-hidden="true">{note}</span>
</span>
