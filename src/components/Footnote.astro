---
interface Props {
  note: string;
}

const { note } = Astro.props;
const id = `fn-${Math.random().toString(36).slice(2, 8)}`;
---

<span class="fn-wrap">
  <button
    class="fn-marker"
    type="button"
    aria-expanded="false"
    aria-describedby={id}
  >*</button>
  <span class="fn-tooltip" id={id} role="tooltip" aria-hidden="true">{note}</span>
</span>

<style>
.fn-wrap {
  position: relative;
  display: inline;
}

.fn-marker {
  all: unset;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7em;
  font-weight: 700;
  color: var(--emerald, rgb(21, 219, 149));
  cursor: default;
  vertical-align: super;
  line-height: 1;
  padding: 0 0.1em;
  border-radius: 2px;
  transition: color 0.15s ease;
}

.fn-marker:hover,
.fn-marker:focus-visible {
  color: rgb(106, 241, 194);
}

.fn-tooltip {
  display: none;
  position: absolute;
  bottom: calc(100% + 0.5rem);
  left: 50%;
  transform: translateX(-50%);
  width: max-content;
  max-width: 320px;
  padding: 0.65rem 0.85rem;
  font-size: 0.82rem;
  font-style: normal;
  font-weight: 400;
  line-height: 1.5;
  color: var(--text, #e8eaf0);
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  border-left: 2px solid var(--emerald, rgb(21, 219, 149));
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.fn-tooltip[aria-hidden="false"] {
  display: block;
}

/* Arrow */
.fn-tooltip::after {
  content: "";
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border: 6px solid transparent;
  border-top-color: var(--bg-border, #242836);
}

/* Mobile: position tooltip more centrally */
@media (max-width: 640px) {
  .fn-tooltip {
    position: fixed;
    bottom: auto;
    top: auto;
    left: 1rem;
    right: 1rem;
    transform: none;
    width: auto;
    max-width: none;
  }
  .fn-tooltip::after {
    display: none;
  }
}
</style>

<script>
function initFootnotes() {
  document.querySelectorAll('.fn-wrap').forEach((wrap) => {
    const btn = wrap.querySelector('.fn-marker') as HTMLButtonElement;
    const tip = wrap.querySelector('.fn-tooltip') as HTMLElement;
    if (!btn || !tip) return;

    function show() {
      tip.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
    }

    function hide() {
      tip.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
    }

    // Hover
    wrap.addEventListener('mouseenter', show);
    wrap.addEventListener('mouseleave', hide);

    // Focus / blur
    btn.addEventListener('focus', show);
    btn.addEventListener('blur', hide);

    // Toggle on click/tap
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = tip.getAttribute('aria-hidden') === 'false';
      if (open) hide(); else show();
    });

    // Escape key closes
    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        hide();
        btn.blur();
      }
    });
  });

  // Click outside closes all
  document.addEventListener('click', () => {
    document.querySelectorAll('.fn-tooltip[aria-hidden="false"]').forEach((tip) => {
      tip.setAttribute('aria-hidden', 'true');
      const btn = tip.previousElementSibling as HTMLElement;
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  });
}

// Run on load and on Astro page transitions
initFootnotes();
document.addEventListener('astro:page-load', initFootnotes);
</script>
