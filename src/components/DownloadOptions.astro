---
import type { LicenseEntryT } from "../_types/licenses";
import { GITHUB_DISCUSSIONS, licenseUrl } from "../utils/constants";
import { derivePlainId } from "../utils/plain-id";
import { ICONS, MATERIAL_ICONS } from "./license/icons";

interface Props {
  license: LicenseEntryT;
  processedBody?: string;
}

const { license, processedBody } = Astro.props;
const { data } = license;
const clipboardContent = processedBody || license.body;

const rawSpdxId = data.spdx_id || data.original?.spdx_id;
if (!rawSpdxId) {
  throw new Error(`License "${license.id}" is missing spdx_id and original.spdx_id`);
}
const plainId = data.plain_id || derivePlainId(rawSpdxId);
const spdxDir = rawSpdxId.toLowerCase();
const version = data.plain_version;
const baseName = `${plainId}-${version}`;
const exportBase = `/exports/${spdxDir}/${version}/`;

const formats = [
  {
    name: "Markdown (GFM)",
    ext: ".gfm.md",
    path: `${exportBase}${baseName}.gfm.md`,
    icon: "markdown",
  },
  {
    name: "Markdown (CommonMark)",
    ext: ".cm.md",
    path: `${exportBase}${baseName}.cm.md`,
    icon: "markdown",
  },
  {
    name: "Plaintext",
    ext: ".txt",
    path: `${exportBase}${baseName}.txt`,
    icon: "file-text",
  },
  {
    name: "PDF",
    ext: ".pdf",
    path: `${exportBase}${baseName}.pdf`,
    icon: "file-text",
  },
  {
    name: "Embed HTML",
    ext: ".html",
    path: `${exportBase}${baseName}-embed.html`,
    icon: "code",
  },
  {
    name: "SPDX XML",
    ext: ".xml",
    path: `${exportBase}${baseName}.xml`,
    icon: "tag",
  },
];

const embedUrl = licenseUrl(`${data.license_family}/${spdxDir}`);
const iframeCode = `<iframe
  src="${embedUrl}"
  style="width: 100%; height: 600px; border: none;"
  title="${data.plain_name}"
  loading="lazy"
  sandbox="allow-scripts allow-same-origin"
></iframe>`;
---

<section class="download-section" aria-labelledby="download-heading">
  <h3 id="download-heading">Get this license</h3>
  <ul class="download-grid" aria-label="Download formats">
    {
      formats.map((format) => (
        <li>
          <a
            href={format.path}
            class="download-card"
            download
            aria-label={`Download ${data.plain_name} as ${format.name} (${format.ext})`}
          >
            {MATERIAL_ICONS.has(format.icon) ? (
              <svg
                class="format-icon"
                viewBox="0 -960 960 960"
                fill="currentColor"
                aria-hidden="true"
                set:html={ICONS[format.icon] ?? ""}
              />
            ) : (
              <svg
                class="format-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={ICONS[format.icon] ?? ""}
              />
            )}
            <span class="format-name">{format.name}</span>
            <span class="format-ext">{format.ext}</span>
          </a>
        </li>
      ))
    }
    <li>
      <button
        type="button"
        class="download-card embed-toggle"
        id="embed-toggle"
        aria-expanded="false"
        aria-controls="embed-panel"
        aria-label="Show embedding options and instructions"
      >
        <svg
          class="format-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          set:html={ICONS.code ?? ""}
        />
        <span class="format-name">How to embed</span>
        <span class="format-ext">options</span>
      </button>
    </li>
  </ul>

  <!-- Embed instructions panel -->
  <div
    id="embed-panel"
    class="embed-panel"
    role="region"
    aria-labelledby="embed-panel-heading"
    tabindex="-1"
    hidden
  >
    <div class="embed-panel-header">
      <h4 id="embed-panel-heading">Embed this license</h4>
      <button
        type="button"
        class="embed-close"
        id="embed-close"
        aria-label="Close embed instructions"
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>

    <p class="embed-intro">
      The <strong>Embed HTML</strong> download above is a self-contained HTML
      file with the full license text and inlined styles. Drop it into your
      project, serve it in an iframe, or include it directly. It auto-adapts to
      light and dark mode via <code>prefers-color-scheme</code>.
    </p>

    <details class="embed-details">
      <summary>Use as an iframe</summary>
      <p>Copy the code below to embed the live version from Plain License:</p>
      <div class="embed-code-block" role="group" aria-label="Iframe code snippet">
        <pre><code id="embed-code">{iframeCode}</code></pre>
        <button
          type="button"
          class="embed-copy-btn"
          id="embed-copy"
          aria-label="Copy iframe code to clipboard"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={ICONS.copy ?? ""}
          />
          <span>Copy</span>
        </button>
        <div
          id="embed-copy-status"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          class="sr-only"
        >
        </div>
      </div>
      <p>
        The iframe renders the full license page (dark theme) and stays
        up&#8209;to&#8209;date automatically. For offline use or theme
        adaptation, use the Embed HTML download instead.
      </p>
    </details>

    <details class="embed-details">
      <summary>Customise the embed file</summary>
      <p>
        The embed file uses CSS custom properties you can override from a parent
        element or your own stylesheet:
      </p>
      <pre><code>{`/* Override on the embed container or :root */
.pl-embed {
  --pl-bg: #your-background;
  --pl-text: #your-text-color;
  --pl-accent: #your-accent-color;
  --pl-border: #your-border-color;
  --pl-surface: #your-surface-color;
}`}</code></pre>
      <p>
        Or simply let <code>prefers-color-scheme</code> handle it &mdash; the
        file ships with light and dark modes that match your visitors' system
        preference.
      </p>
    </details>

    <p class="embed-help">
      Need help? Ask in our <a
        href={GITHUB_DISCUSSIONS}
        >GitHub Discussions</a
      >.
    </p>
  </div>

  <button
    id="copy-clipboard"
    type="button"
    class="copy-button"
    data-content={clipboardContent}
    aria-label="Copy license text to clipboard"
  >
    <svg
      class="copy-icon"
      viewBox="0 -960 960 960"
      fill="currentColor"
      aria-hidden="true"
      set:html={ICONS["markdown-paste"] ?? ""}
    />
    <span>Copy to Clipboard</span>
  </button>
  <div
    id="copy-status"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    class="sr-only"
  >
  </div>
</section>

<script>
  // Clipboard copy for full license text
  const button = document.getElementById("copy-clipboard");
  const statusEl = document.getElementById("copy-status");
  if (button) {
    const label = button.querySelector("span");
    button.addEventListener("click", () => {
      const content = button.dataset.content || "";
      navigator.clipboard
        .writeText(content)
        .then(() => {
          if (label) {
            const originalText = label.textContent;
            label.textContent = "Copied!";
            button.classList.add("success");
            if (statusEl)
              statusEl.textContent = "License text copied to clipboard.";
            setTimeout(() => {
              label.textContent = originalText;
              button.classList.remove("success");
              if (statusEl) statusEl.textContent = "";
            }, 2000);
          }
        })
        .catch(() => {
          if (statusEl) statusEl.textContent = "Copy failed. Please try again.";
        });
    });
  }

  // Embed panel toggle with focus management
  const embedToggle = document.getElementById("embed-toggle");
  const embedPanel = document.getElementById("embed-panel");
  const embedClose = document.getElementById("embed-close");

  function toggleEmbed(show?: boolean) {
    if (!embedPanel || !embedToggle) return;
    const isHidden = embedPanel.hidden;
    const shouldShow = show ?? isHidden;
    embedPanel.hidden = !shouldShow;
    embedToggle.setAttribute("aria-expanded", String(shouldShow));
    if (shouldShow) {
      embedToggle.classList.add("active");
      // Move focus into the panel so keyboard users land on it
      embedPanel.focus();
    } else {
      embedToggle.classList.remove("active");
      // Return focus to the toggle button
      embedToggle.focus();
    }
  }

  embedToggle?.addEventListener("click", () => toggleEmbed());
  embedClose?.addEventListener("click", () => toggleEmbed(false));

  // Close embed panel on Escape
  embedPanel?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") {
      toggleEmbed(false);
    }
  });

  // Copy embed code with live region announcement
  const embedCopy = document.getElementById("embed-copy");
  const embedCodeEl = document.getElementById("embed-code");
  const embedCopyStatus = document.getElementById("embed-copy-status");
  if (embedCopy && embedCodeEl) {
    embedCopy.addEventListener("click", () => {
      const code = embedCodeEl.textContent || "";
      navigator.clipboard
        .writeText(code)
        .then(() => {
          const label = embedCopy.querySelector("span");
          if (label) {
            label.textContent = "Copied!";
            embedCopy.classList.add("success");
            if (embedCopyStatus)
              embedCopyStatus.textContent = "Embed code copied to clipboard.";
            setTimeout(() => {
              label.textContent = "Copy";
              embedCopy.classList.remove("success");
              if (embedCopyStatus) embedCopyStatus.textContent = "";
            }, 2000);
          }
        })
        .catch(() => {
          if (embedCopyStatus)
            embedCopyStatus.textContent = "Copy failed. Please try again.";
        });
    });
  }
</script>

<style>
  .format-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--sl-color-gray-3);
    transition: color 0.2s;
  }

  .download-section {
    margin-top: 4rem;
    padding: 2rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-top: 3px solid var(--cat-color, var(--sl-color-accent));
    border-radius: 12px;
  }
  h3 {
    margin-top: 0;
    color: var(--cat-color, var(--sl-color-accent));
    font-size: var(--sl-text-xl);
  }
  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .download-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1rem;
    background: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 8px;
    text-decoration: none;
    color: var(--sl-color-gray-1);
    transition: all 0.2s;
    cursor: pointer;
  }
  .download-card:hover {
    background: var(--sl-color-gray-4);
    border-color: var(--cat-color, var(--sl-color-accent));
    transform: translateY(-2px);
    color: var(--cat-color, var(--sl-color-accent));
  }
  .download-card:hover .format-icon {
    color: var(--cat-color, var(--sl-color-accent));
  }
  button.download-card {
    font-family: inherit;
    font-size: inherit;
  }

  .embed-toggle {
    width: 100%;
  }

  .embed-toggle.active {
    background: var(--sl-color-gray-4);
    border-color: var(--cat-color, var(--sl-color-accent));
    color: var(--cat-color, var(--sl-color-accent));
  }
  .embed-toggle.active .format-icon {
    color: var(--cat-color, var(--sl-color-accent));
  }

  .format-name {
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
  }
  .format-ext {
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
  }

  /* ── Focus indicators ── */
  .download-card:focus-visible,
  .embed-toggle:focus-visible,
  .embed-close:focus-visible,
  .embed-copy-btn:focus-visible,
  .copy-button:focus-visible {
    outline: 2px solid var(--cat-color, var(--sl-color-accent));
    outline-offset: 2px;
  }
  .embed-panel:focus {
    outline: none;
  }
  .embed-details summary:focus-visible {
    outline: 2px solid var(--cat-color, var(--sl-color-accent));
    outline-offset: -2px;
  }

  /* ── Embed panel ── */
  .embed-panel {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 8px;
    animation: embed-slide-in 0.2s ease-out;
  }
  @keyframes embed-slide-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .embed-panel {
      animation: none;
    }
    .download-card {
      transition: none;
    }
  }
  .embed-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .embed-panel-header h4 {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 1rem;
  }
  .embed-close {
    background: none;
    border: none;
    color: var(--sl-color-gray-3);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.15s;
  }
  .embed-close:hover {
    color: var(--sl-color-white);
  }
  .embed-intro {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .embed-code-block {
    position: relative;
    margin-bottom: 1rem;
  }
  .embed-code-block pre {
    margin: 0;
    padding: 1rem;
    padding-right: 4.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.6;
  }
  .embed-code-block code {
    color: var(--sl-color-gray-1);
    white-space: pre;
  }
  .embed-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.6rem;
    background: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 4px;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }
  .embed-copy-btn svg {
    width: 0.9rem;
    height: 0.9rem;
  }
  .embed-copy-btn:hover {
    border-color: var(--cat-color, var(--sl-color-accent));
    color: var(--cat-color, var(--sl-color-accent));
  }
  .embed-copy-btn.success {
    border-color: var(--success-green);
    color: var(--success-green);
  }

  /* ── Embed details (accordion sections) ── */
  .embed-details {
    margin-bottom: 0.5rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 6px;
    overflow: hidden;
  }
  .embed-details summary {
    padding: 0.6rem 1rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-1);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: color 0.15s;
    list-style: none;
  }
  .embed-details summary::-webkit-details-marker {
    display: none;
  }
  .embed-details summary::before {
    content: "▸ ";
    color: var(--sl-color-gray-3);
    transition: transform 0.15s;
    display: inline-block;
  }
  .embed-details[open] summary::before {
    content: "▾ ";
  }
  .embed-details summary:hover {
    color: var(--cat-color, var(--sl-color-accent));
  }
  .embed-details > :not(summary) {
    padding: 0 1rem;
  }
  .embed-details p {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    line-height: 1.5;
    margin: 0.75rem 0;
  }
  .embed-details code {
    background: var(--sl-color-gray-5);
    border-radius: 3px;
    padding: 0.1em 0.3em;
    font-size: 0.85em;
  }
  .embed-details pre {
    margin: 0.75rem 0;
    padding: 0.75rem 1rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.5;
  }
  .embed-details pre code {
    background: none;
    padding: 0;
    color: var(--sl-color-gray-1);
    white-space: pre;
  }
  .embed-help {
    margin: 1rem 0 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .embed-help a {
    color: var(--cat-color, var(--sl-color-accent));
  }

  /* ── Copy to clipboard button ── */
  .copy-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85rem;
    background: transparent;
    color: var(--sl-color-gray-1);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .copy-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }
  .copy-button:hover {
    border-color: var(--cat-color, var(--sl-color-accent));
    color: var(--cat-color, var(--sl-color-accent));
  }
  .copy-button.success {
    background: rgba(var(--success-green-rgb), 0.15);
    border-color: var(--success-green);
    color: var(--success-green);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
