---
interface Props {
  originalHtml: string;
  spdxId: string;
}

const { originalHtml, spdxId } = Astro.props;
---

<div class="compare-layout" data-spdx-id={spdxId}>
  <div class="compare-original" id="compare-original" role="region" aria-label="Original license text">
    <div class="column-badge column-badge--original">
      <svg class="column-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" />
      </svg>
      Original
    </div>
    <div class="compare-original-text prose" id="compare-original-text" set:html={originalHtml} />
  </div>

  <div class="compare-teleprompter" id="compare-teleprompter" role="complementary" aria-label="Plain language equivalent">
    <div class="column-badge column-badge--plain">
      <svg class="column-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
      </svg>
      Plain Language
    </div>
    <div class="teleprompter-content" id="teleprompter-content" aria-live="polite">
      <p class="teleprompter-instruction">Hover underlined text to see the plain language version</p>
    </div>
  </div>
</div>

<!-- Mobile modal for concept display -->
<div id="concept-modal" class="concept-modal" aria-modal="true" aria-labelledby="concept-modal-title" aria-hidden="true">
  <div class="concept-modal-overlay"></div>
  <div class="concept-modal-content">
    <div class="concept-modal-header">
      <h3 id="concept-modal-title">Plain Language Version</h3>
      <button class="concept-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="concept-modal-body" id="concept-modal-body"></div>
  </div>
</div>
