{
  "$schema": "https://biomejs.dev/schemas/2.0.0-beta.2/schema.json",
  // since we extend the base, we are only defining differences
  "extends": ["../../biome.jsonc"],
  "files": {
    "includes": ["**/*.{ts,js,json}", "../../commitlint.config.ts"]
  },
  "linter": {
    "rules": {
      // because the build script is node, we need to allow nodejs modules
      "correctness": {
        "noNodejsModules": "off"
      },
      "style": {
        "noNamespaceImport": "off"
      }
    }
  }
}
