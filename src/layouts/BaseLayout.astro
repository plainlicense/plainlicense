---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

import {
  FAVICON_PATH,
  GITHUB_REPO,
  ROUTES,
  SITE_TAGLINE,
} from "../utils/constants";
import "../assets/stylesheets/tokens.css";
import "../assets/stylesheets/buttons.css";
import "../assets/stylesheets/print.css";

const {
  title,
  description = "Plain language versions of popular licenses",
  ogImage,
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`/open-graph${currentPath.replace(/\/$/, "")}.png`, Astro.site)
      .href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={FAVICON_PATH} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Plain License</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Plain License`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Plain License" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Plain License`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-brand" aria-label="Plain License home">
          <img
            src={FAVICON_PATH}
            alt=""
            class="brand-logo"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="brand-name">Plain <strong>License</strong></span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}
            >Home</a
          >
          <a
            href={ROUTES.LICENSES}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.LICENSES) },
            ]}>Licenses</a
          >
          <a
            href={ROUTES.FAQ}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.FAQ) },
            ]}>FAQ</a
          >
          <a
            href={ROUTES.ABOUT}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.ABOUT) },
            ]}>About</a
          >
          <a
            href={ROUTES.BLOG}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.BLOG) },
            ]}>Blog</a
          >
          <button
            type="button"
            class="search-trigger"
            data-open-search
            aria-label="Search site"
            aria-keyshortcuts="Control+K"
          >
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <span class="search-trigger__label">Search</span>
            <kbd class="search-trigger__kbd"><span class="search-trigger__key"></span>K</kbd>
          </button>
          <a
            href={GITHUB_REPO}
            class="nav-link nav-github"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository (opens in new tab)"
          >
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </a>
        </nav>
        <button
          type="button"
          class="mobile-menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Toggle navigation"
        >
          <span></span><span></span><span></span>
        </button>
      </div>
      <nav
        id="mobile-nav"
        class="mobile-nav"
        aria-label="Mobile navigation"
        hidden
      >
        <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}
          >Home</a
        >
        <a
          href={ROUTES.LICENSES}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.LICENSES) },
          ]}>Licenses</a
        >
        <a
          href={ROUTES.FAQ}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.FAQ) },
          ]}>FAQ</a
        >
        <a
          href={ROUTES.ABOUT}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.ABOUT) },
          ]}>About</a
        >
        <a
          href={ROUTES.BLOG}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.BLOG) },
          ]}>Blog</a
        >
        <button
          type="button"
          class="nav-link search-trigger-mobile"
          data-open-search
          aria-label="Search site"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Search
        </button>
        <a
          href={GITHUB_REPO}
          class="nav-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository (opens in new tab)"
        >
          GitHub
        </a>
      </nav>
    </header>
    <main class="page-main" id="main-content"><slot /></main>

    <!-- Search modal -->
    <dialog class="search-dialog" aria-label="Search site">
      <div class="search-dialog__frame">
        <div id="base-search"></div>
      </div>
    </dialog>
    <link rel="stylesheet" href="/_pagefind/pagefind-ui.css" />
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img
            src={FAVICON_PATH}
            alt=""
            class="footer-logo"
            width="24"
            height="24"
            aria-hidden="true"
          />
          <span class="footer-tagline">{SITE_TAGLINE}</span>
        </div>
        <p class="footer-copy">
          Plain License's authors dedicate all original content to the public
          domain.
          <strong>We reserve NO rights.</strong>
        </p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href={ROUTES.LICENSES}>Licenses</a>
          <a href={ROUTES.FAQ}>FAQ</a>
          <a href={ROUTES.ABOUT}>About</a>
          <a href={ROUTES.HELPING}>Contributing</a>
          <a href={ROUTES.BLOG}>Blog</a>
          <a
            href={GITHUB_REPO}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub (opens in new tab)">GitHub</a
          >
        </nav>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggle = document.querySelector(
    ".mobile-menu-toggle",
  ) as HTMLButtonElement | null;
  const mobileNav = document.getElementById("mobile-nav");
  if (toggle && mobileNav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      if (expanded) {
        mobileNav.setAttribute("hidden", "");
      } else {
        mobileNav.removeAttribute("hidden");
      }
    });
  }

  // ── Platform key detection for search trigger ──
  (() => {
    const keySpans = document.querySelectorAll('.search-trigger__key');
    const isMac = /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform);
    keySpans.forEach(span => { span.textContent = isMac ? '\u2318' : 'Ctrl+'; });

    document.querySelectorAll('[data-open-search]').forEach(btn => {
      if (isMac) btn.setAttribute('aria-keyshortcuts', 'Meta+K');
    });
  })();

  // ── Search command palette (Pagefind UI) ──
  (() => {
    const dialog = document.querySelector('.search-dialog') as HTMLDialogElement | null;
    if (!dialog) return;

    let uiInitialized = false;

    function initPagefindUI() {
      if (uiInitialized) return;
      uiInitialized = true;
      const script = document.createElement('script');
      script.src = '/_pagefind/pagefind-ui.js';
      script.onload = () => {
        // @ts-ignore — PagefindUI is loaded externally
        new (window as any).PagefindUI({
          element: '#base-search',
          showSubResults: true,
          showImages: false,
          autofocus: true,
        });
      };
      document.head.appendChild(script);
    }

    const openSearch = () => {
      initPagefindUI();
      dialog.showModal();
      requestAnimationFrame(() => {
        const input = dialog.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (input) { input.focus(); input.select(); }
      });
    };

    const closeSearch = () => {
      dialog.close();
    };

    document.querySelectorAll('[data-open-search]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        openSearch();
      });
    });

    window.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        dialog.open ? closeSearch() : openSearch();
      }
      if (e.key === '/' && !dialog.open && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement)) {
        e.preventDefault();
        openSearch();
      }
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeSearch();
    });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
    });
  })();

  // Print: force all <details> open and all tab panels visible
  window.addEventListener("beforeprint", () => {
    document.querySelectorAll("details:not([open])").forEach((d) => {
      d.setAttribute("open", "");
      d.setAttribute("data-print-opened", "");
    });
    document
      .querySelectorAll<HTMLElement>(".tab-panel[hidden]")
      .forEach((p) => {
        p.removeAttribute("hidden");
        p.setAttribute("data-print-shown", "");
      });
  });

  window.addEventListener("afterprint", () => {
    document.querySelectorAll("[data-print-opened]").forEach((d) => {
      d.removeAttribute("open");
      d.removeAttribute("data-print-opened");
    });
    document
      .querySelectorAll<HTMLElement>("[data-print-shown]")
      .forEach((p) => {
        p.setAttribute("hidden", "");
        p.removeAttribute("data-print-shown");
      });
  });
</script>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  :root {
    /* Map legacy BaseLayout vars to shared tokens */
    --accent: var(--emerald-rgb);
    --accent-dark: var(--castleton-grn-rgb);
    --accent-text: var(--aquamarine-rgb);
    --bg: var(--pl-bg);
    --bg-surface: var(--pl-surface);
    --bg-border: var(--pl-border);
    --text: var(--pl-text);
    --text-muted: var(--pl-text-muted);
    --header-h: 3.5rem;
  }

  html {
    font-family: var(--sl-font, "Lexend", "Noto Sans", system-ui, sans-serif);
    background: var(--bg);
    color: var(--text);
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  body {
    margin: 0;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .page-main {
    flex: 1;
  }

  /* ── Skip Link ──────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    background: rgb(var(--accent));
    color: #0d0f15;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: top 0.1s;
  }

  .skip-link:focus {
    top: 0.5rem;
  }

  /* ── Global Focus Styles ─────────────────────────────────── */
  :focus-visible {
    outline: 2px solid rgb(var(--accent));
    outline-offset: 2px;
  }

  /* Remove default outline only when :focus-visible is used */
  :focus:not(:focus-visible) {
    outline: none;
  }

  code {
    font-family: var(--sl-font-mono, "JetBrains Mono", "Fira Code", monospace);
  }

  a {
    color: rgb(var(--accent));
  }
  a:hover {
    color: rgb(var(--accent-text));
  }

  /* ── Site Header ─────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(13, 15, 21, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bg-border);
  }

  .header-inner {
    max-width: var(--pl-width-page, 72rem);
    margin: 0 auto;
    padding: 0 var(--pl-gutter, 1.5rem);
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text);
    flex-shrink: 0;
  }

  .brand-logo {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
  }

  .brand-name {
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .brand-name strong {
    font-weight: 700;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-muted);
    transition:
      color 0.15s,
      background 0.15s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-github {
    margin-left: 0.5rem;
  }

  /* ── Search Trigger ─────────────────────────────────────── */
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: inherit;
    transition:
      border-color 0.15s,
      color 0.15s,
      background 0.15s;
    margin-left: 0.25rem;
    flex-shrink: 0;
  }

  .search-trigger:hover {
    border-color: rgba(var(--accent), 0.4);
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .search-trigger__label {
    font-weight: 500;
  }

  .search-trigger__kbd {
    display: inline-flex;
    align-items: center;
    gap: 0.1em;
    margin-left: 0.25rem;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--bg-border);
    font-size: 0.7rem;
    font-family: inherit;
    color: var(--text-muted);
    line-height: 1;
  }

  .search-trigger-mobile {
    gap: 0.5rem;
  }

  /* ── Search Dialog ──────────────────────────────────────── */
  .search-dialog {
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
  }

  .search-dialog[open] {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }

  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(6px);
  }

  .search-dialog__frame {
    width: 90%;
    max-width: 560px;
    max-height: 70vh;
    background: var(--bg-surface);
    border: 1px solid var(--bg-border);
    border-radius: 12px;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    overflow-y: auto;
  }

  /* ── Pagefind UI Dark Theme Overrides ───────────────────── */
  .search-dialog :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: rgb(var(--accent));
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--bg-border);
    --pagefind-ui-tag: rgba(255, 255, 255, 0.06);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--sl-font, "Lexend", "Noto Sans", system-ui, sans-serif);
  }

  .search-dialog :global(.pagefind-ui__search-input) {
    background: transparent;
    color: var(--text);
    font-family: inherit;
  }

  .search-dialog :global(.pagefind-ui__search-input::placeholder) {
    color: rgba(206, 208, 215, 0.5);
  }

  .search-dialog :global(.pagefind-ui__search-clear) {
    color: var(--text-muted);
    background: transparent;
  }

  .search-dialog :global(.pagefind-ui__result-link) {
    color: var(--text);
  }

  .search-dialog :global(.pagefind-ui__result-link:hover) {
    color: rgb(var(--accent));
  }

  .search-dialog :global(.pagefind-ui__result-excerpt) {
    color: var(--text-muted);
  }

  .search-dialog :global(.pagefind-ui__result-excerpt mark) {
    color: rgb(var(--accent-text));
    background: transparent;
    font-weight: 600;
  }

  .search-dialog :global(.pagefind-ui__message) {
    color: var(--text-muted);
  }

  .search-dialog :global(.pagefind-ui__button) {
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--bg-border);
  }

  .search-dialog :global(.pagefind-ui__button:hover) {
    border-color: rgba(var(--accent), 0.4);
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    margin-left: auto;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    border-top: 1px solid var(--bg-border);
    background: var(--bg-surface);
  }

  /* Respect the `hidden` attribute — prevents CSS flex from overriding it */
  .mobile-nav[hidden] {
    display: none;
  }

  .mobile-nav .nav-link {
    padding: 0.7rem 0.5rem;
    font-size: 1rem;
    border-bottom: 1px solid var(--bg-border);
  }

  @media (max-width: 640px) {
    .site-nav {
      display: none;
    }
    .mobile-menu-toggle {
      display: flex;
    }
  }

  /* ── Site Footer ─────────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--bg-border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--pl-width-page, 72rem);
    margin: 0 auto;
    padding: var(--pl-space-lg, 2rem) var(--pl-gutter, 1.5rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  .footer-logo {
    width: 1.5rem;
    height: 1.5rem;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .footer-copy {
    margin: 0;
  }
  .footer-copy strong {
    color: var(--text);
  }

  .footer-nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer-nav a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: rgb(var(--accent));
  }

  /* ── Prose base ──────────────────────────────────────────── */
  .prose {
    line-height: var(--pl-line-height, 1.7);
    max-width: none;
  }

  .prose h1,
  .prose h2,
  .prose h3 {
    color: var(--pl-accent, var(--text));
    line-height: var(--pl-line-height-tight, 1.3);
  }

  .prose a {
    color: var(--pl-accent, rgb(var(--accent)));
    text-decoration: underline;
    text-decoration-color: rgba(var(--pl-accent-rgb), 0.35);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition:
      color var(--pl-transition-fast, 0.15s ease),
      text-decoration-color var(--pl-transition-fast, 0.15s ease);
  }

  .prose a:hover {
    color: var(--pl-accent-hover, rgb(var(--accent-text)));
    text-decoration-color: var(--pl-accent-hover);
