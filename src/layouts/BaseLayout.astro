---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

import {
  FAVICON_PATH,
  GITHUB_REPO,
  ROUTES,
  SITE_TAGLINE,
} from "../utils/constants";
import "../assets/stylesheets/tokens.css";
import "../assets/stylesheets/buttons.css";
import "../assets/stylesheets/print.css";

const {
  title,
  description = "Plain language versions of popular licenses",
  ogImage,
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site);
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`/open-graph${currentPath.replace(/\/$/, "")}.png`, Astro.site)
      .href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={FAVICON_PATH} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Plain License</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Plain License`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Plain License" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Plain License`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-brand" aria-label="Plain License home">
          <img
            src={FAVICON_PATH}
            alt=""
            class="brand-logo"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="brand-name">Plain <strong>License</strong></span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}
            >Home</a
          >
          <a
            href={ROUTES.LICENSES}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.LICENSES) },
            ]}>Licenses</a
          >
          <a
            href={ROUTES.FAQ}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.FAQ) },
            ]}>FAQ</a
          >
          <a
            href={ROUTES.ABOUT}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.ABOUT) },
            ]}>About</a
          >
          <a
            href={ROUTES.BLOG}
            class:list={[
              "nav-link",
              { active: currentPath.startsWith(ROUTES.BLOG) },
            ]}>Blog</a
          >
          <button
            type="button"
            class="search-trigger"
            data-open-search
            aria-label="Search site"
            aria-keyshortcuts="Control+K"
          >
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <span class="search-trigger__label">Search</span>
            <kbd class="search-trigger__kbd"><span class="search-trigger__key"></span>K</kbd>
          </button>
          <a
            href={GITHUB_REPO}
            class="nav-link nav-github"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository (opens in new tab)"
          >
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </a>
        </nav>
        <button
          type="button"
          class="mobile-menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Toggle navigation"
        >
          <span></span><span></span><span></span>
        </button>
      </div>
      <nav
        id="mobile-nav"
        class="mobile-nav"
        aria-label="Mobile navigation"
        hidden
      >
        <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}
          >Home</a
        >
        <a
          href={ROUTES.LICENSES}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.LICENSES) },
          ]}>Licenses</a
        >
        <a
          href={ROUTES.FAQ}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.FAQ) },
          ]}>FAQ</a
        >
        <a
          href={ROUTES.ABOUT}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.ABOUT) },
          ]}>About</a
        >
        <a
          href={ROUTES.BLOG}
          class:list={[
            "nav-link",
            { active: currentPath.startsWith(ROUTES.BLOG) },
          ]}>Blog</a
        >
        <button
          type="button"
          class="nav-link search-trigger-mobile"
          data-open-search
          aria-label="Search site"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Search
        </button>
        <a
          href={GITHUB_REPO}
          class="nav-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository (opens in new tab)"
        >
          GitHub
        </a>
      </nav>
    </header>
    <main class="page-main" id="main-content"><slot /></main>

    <!-- Search modal -->
    <dialog class="search-dialog" aria-label="Search site">
      <div class="search-dialog__frame">
        <div class="search-dialog__input-row">
          <svg class="search-dialog__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input
            type="search"
            class="search-dialog__input"
            placeholder="Search licenses, pages, blog..."
            aria-label="Search"
            autocomplete="off"
            autofocus
          />
          <kbd class="search-dialog__esc">Esc</kbd>
        </div>
        <div class="search-dialog__results" id="base-search-results"></div>
        <div class="search-dialog__empty" hidden>
          <p>No results found. Try a different search term.</p>
        </div>
        <div class="search-dialog__footer">
          <span class="search-dialog__hint">
            <kbd>&uarr;</kbd><kbd>&darr;</kbd> to navigate
            <kbd>Enter</kbd> to open
            <kbd>Esc</kbd> to close
          </span>
        </div>
      </div>
    </dialog>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img
            src={FAVICON_PATH}
            alt=""
            class="footer-logo"
            width="24"
            height="24"
            aria-hidden="true"
          />
          <span class="footer-tagline">{SITE_TAGLINE}</span>
        </div>
        <p class="footer-copy">
          Plain License's authors dedicate all original content to the public
          domain.
          <strong>We reserve NO rights.</strong>
        </p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href={ROUTES.LICENSES}>Licenses</a>
          <a href={ROUTES.FAQ}>FAQ</a>
          <a href={ROUTES.ABOUT}>About</a>
          <a href={ROUTES.HELPING}>Contributing</a>
          <a href={ROUTES.BLOG}>Blog</a>
          <a
            href={GITHUB_REPO}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub (opens in new tab)">GitHub</a
          >
        </nav>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggle = document.querySelector(
    ".mobile-menu-toggle",
  ) as HTMLButtonElement | null;
  const mobileNav = document.getElementById("mobile-nav");
  if (toggle && mobileNav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      if (expanded) {
        mobileNav.setAttribute("hidden", "");
      } else {
        mobileNav.removeAttribute("hidden");
      }
    });
  }

  // ── Platform key detection for search trigger ──
  (() => {
    const keySpans = document.querySelectorAll('.search-trigger__key');
    const isMac = /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform);
    keySpans.forEach(span => { span.textContent = isMac ? '\u2318' : 'Ctrl+'; });

    document.querySelectorAll('[data-open-search]').forEach(btn => {
      if (isMac) btn.setAttribute('aria-keyshortcuts', 'Meta+K');
    });
  })();

  // ── Search command palette ──
  (() => {
    const dialog = document.querySelector('.search-dialog') as HTMLDialogElement | null;
    const input = dialog?.querySelector('.search-dialog__input') as HTMLInputElement | null;
    const resultsContainer = dialog?.querySelector('.search-dialog__results') as HTMLElement | null;
    const emptyState = dialog?.querySelector('.search-dialog__empty') as HTMLElement | null;
    if (!dialog || !input || !resultsContainer || !emptyState) return;

    let pagefind: any = null;
    let selectedIndex = -1;

    const openSearch = () => {
      dialog.showModal();
      input.focus();
      input.select();
    };

    const closeSearch = () => {
      dialog.close();
    };

    document.querySelectorAll('[data-open-search]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        openSearch();
      });
    });

    window.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        dialog.open ? closeSearch() : openSearch();
      }
      if (e.key === '/' && !dialog.open && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement)) {
        e.preventDefault();
        openSearch();
      }
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeSearch();
    });

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        // Dynamic path prevents Vite from bundling this — Pagefind is generated post-build
        const pfPath = ['', '_pagefind', 'pagefind.js'].join('/');
        pagefind = await import(/* @vite-ignore */ pfPath);
        await pagefind.init();
      } catch {
        pagefind = null;
      }
      return pagefind;
    }

    function createResultElement(result: { url: string; meta?: { title?: string }; excerpt?: string }, index: number): HTMLAnchorElement {
      const a = document.createElement('a');
      a.href = result.url;
      a.className = 'search-result';
      a.dataset.index = String(index);

      const title = document.createElement('span');
      title.className = 'search-result__title';
      title.textContent = result.meta?.title || 'Untitled';
      a.appendChild(title);

      if (result.excerpt) {
        const excerpt = document.createElement('span');
        excerpt.className = 'search-result__excerpt';
        // Pagefind excerpts contain <mark> tags for highlighting.
        // We parse them safely rather than using innerHTML.
        const parts = result.excerpt.split(/(<mark>.*?<\/mark>)/g);
        for (const part of parts) {
          const markMatch = part.match(/^<mark>(.*?)<\/mark>$/);
          if (markMatch) {
            const mark = document.createElement('mark');
            mark.textContent = markMatch[1];
            excerpt.appendChild(mark);
          } else {
            excerpt.appendChild(document.createTextNode(part));
          }
        }
        a.appendChild(excerpt);
      }

      return a;
    }

    function renderResults(results: any[]) {
      resultsContainer.replaceChildren();
      if (results.length === 0) {
        emptyState.hidden = false;
        selectedIndex = -1;
        return;
      }

      emptyState.hidden = true;
      selectedIndex = -1;

      for (let i = 0; i < results.length; i++) {
        resultsContainer.appendChild(createResultElement(results[i], i));
      }
    }

    function updateSelection(newIndex: number) {
      const items = resultsContainer.querySelectorAll('.search-result');
      if (items.length === 0) return;

      if (newIndex < 0) newIndex = items.length - 1;
      if (newIndex >= items.length) newIndex = 0;

      items.forEach((item, i) => {
        item.classList.toggle('search-result--active', i === newIndex);
        if (i === newIndex) {
          (item as HTMLElement).scrollIntoView({ block: 'nearest' });
        }
      });
      selectedIndex = newIndex;
    }

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        updateSelection(selectedIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        updateSelection(selectedIndex - 1);
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        const active = resultsContainer.querySelector('.search-result--active') as HTMLAnchorElement | null;
        if (active) {
          closeSearch();
          window.location.href = active.href;
        }
      }
    });

    let debounceTimer: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const query = input.value.trim();
      if (!query) {
        resultsContainer.replaceChildren();
        emptyState.hidden = true;
        return;
      }

      debounceTimer = setTimeout(async () => {
        const pf = await loadPagefind();
        if (!pf) return;

        const search = await pf.search(query);
        const results = await Promise.all(
          search.results.slice(0, 8).map((r: any) => r.data())
        );
        renderResults(results);
      }, 150);
    });
  })();

  // Print: force all <details> open and all tab panels visible
  window.addEventListener("beforeprint", () => {
    document.querySelectorAll("details:not([open])").forEach((d) => {
      d.setAttribute("open", "");
      d.setAttribute("data-print-opened", "");
    });
    document
      .querySelectorAll<HTMLElement>(".tab-panel[hidden]")
      .forEach((p) => {
        p.removeAttribute("hidden");
        p.setAttribute("data-print-shown", "");
      });
  });

  window.addEventListener("afterprint", () => {
    document.querySelectorAll("[data-print-opened]").forEach((d) => {
      d.removeAttribute("open");
      d.removeAttribute("data-print-opened");
    });
    document
      .querySelectorAll<HTMLElement>("[data-print-shown]")
      .forEach((p) => {
        p.setAttribute("hidden", "");
        p.removeAttribute("data-print-shown");
      });
  });
</script>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  :root {
    /* Map legacy BaseLayout vars to shared tokens */
    --accent: var(--emerald-rgb);
    --accent-dark: var(--castleton-grn-rgb);
    --accent-text: var(--aquamarine-rgb);
    --bg: var(--pl-bg);
    --bg-surface: var(--pl-surface);
    --bg-border: var(--pl-border);
    --text: var(--pl-text);
    --text-muted: var(--pl-text-muted);
    --header-h: 3.5rem;
  }

  html {
    font-family: var(--sl-font, "Lexend", "Noto Sans", system-ui, sans-serif);
    background: var(--bg);
    color: var(--text);
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  body {
    margin: 0;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .page-main {
    flex: 1;
  }

  /* ── Skip Link ──────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    background: rgb(var(--accent));
    color: #0d0f15;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: top 0.1s;
  }

  .skip-link:focus {
    top: 0.5rem;
  }

  /* ── Global Focus Styles ─────────────────────────────────── */
  :focus-visible {
    outline: 2px solid rgb(var(--accent));
    outline-offset: 2px;
  }

  /* Remove default outline only when :focus-visible is used */
  :focus:not(:focus-visible) {
    outline: none;
  }

  code {
    font-family: var(--sl-font-mono, "JetBrains Mono", "Fira Code", monospace);
  }

  a {
    color: rgb(var(--accent));
  }
  a:hover {
    color: rgb(var(--accent-text));
  }

  /* ── Site Header ─────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(13, 15, 21, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bg-border);
  }

  .header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text);
    flex-shrink: 0;
  }

  .brand-logo {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
  }

  .brand-name {
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .brand-name strong {
    font-weight: 700;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-muted);
    transition:
      color 0.15s,
      background 0.15s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-github {
    margin-left: 0.5rem;
  }

  /* ── Search Trigger ─────────────────────────────────────── */
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: inherit;
    transition:
      border-color 0.15s,
      color 0.15s,
      background 0.15s;
    margin-left: 0.25rem;
    flex-shrink: 0;
  }

  .search-trigger:hover {
    border-color: rgba(var(--accent), 0.4);
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .search-trigger__label {
    font-weight: 500;
  }

  .search-trigger__kbd {
    display: inline-flex;
    align-items: center;
    gap: 0.1em;
    margin-left: 0.25rem;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--bg-border);
    font-size: 0.7rem;
    font-family: inherit;
    color: var(--text-muted);
    line-height: 1;
  }

  .search-trigger-mobile {
    gap: 0.5rem;
  }

  /* ── Search Dialog ──────────────────────────────────────── */
  .search-dialog {
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
  }

  .search-dialog[open] {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }

  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(6px);
  }

  .search-dialog__frame {
    width: 90%;
    max-width: 560px;
    max-height: 70vh;
    background: var(--bg-surface);
    border: 1px solid var(--bg-border);
    border-radius: 12px;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .search-dialog__input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--bg-border);
  }

  .search-dialog__icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .search-dialog__input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 1.05rem;
    font-family: inherit;
    outline: none;
  }

  .search-dialog__input::placeholder {
    color: rgba(206, 208, 215, 0.5);
  }

  .search-dialog__esc {
    font-size: 0.7rem;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--bg-border);
    color: var(--text-muted);
    font-family: inherit;
    flex-shrink: 0;
  }

  .search-dialog__results {
    overflow-y: auto;
    padding: 0.5rem;
    max-height: calc(70vh - 7rem);
  }

  .search-dialog__results:empty {
    display: none;
  }

  .search-result {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.1s;
  }

  .search-result:hover,
  .search-result--active {
