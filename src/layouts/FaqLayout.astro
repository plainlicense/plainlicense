---
import BaseLayout from "./BaseLayout.astro";
import "../assets/stylesheets/footnotes.css";
import "../assets/stylesheets/prose.css";
import FootnoteScript from "../components/FootnoteScript.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <div class="content-page faq-page">
    <div class="container">
      <header class="page-header">
        <h1>{frontmatter.title}</h1>
        {
          frontmatter.description && (
            <p class="description">{frontmatter.description}</p>
          )
        }
      </header>

      <article class="prose faq-content"><slot /></article>
    </div>
  </div>
  <FootnoteScript />
</BaseLayout>

<style>
  /*
   * FAQ-specific overrides on top of the shared prose system.
   * Each h2 "question" is styled as a card with an accent left border.
   */
  .faq-content {
    display: flex;
    flex-direction: column;
    gap: var(--pl-space-sm, 0.75rem);
  }

  .faq-content :global(h2) {
    font-size: var(--pl-text-lg, 1.1rem);
    font-weight: 700;
    margin: 0;
    padding: 1.1rem 1.25rem;
    color: var(--pl-text, #e8eaf0);
    background: var(--pl-surface, #161923);
    border: 1px solid var(--pl-border, #242836);
    border-left: 3px solid var(--pl-accent, var(--emerald));
    border-radius: var(--pl-radius-lg, 10px);
    cursor: default;
    line-height: 1.4;
    /* Extra breathing room above each new question */
    margin-top: var(--pl-space-sm, 0.75rem);
  }

  /* First question doesn't need extra top margin */
  .faq-content :global(h2:first-child) {
    margin-top: 0;
  }

  /* Kill bottom margin on last element before next question
     so it doesn't stack with the flex gap */
  .faq-content :global(h2 ~ p:last-child),
  .faq-content :global(h2 ~ ul:last-child),
  .faq-content :global(h2 ~ ol:last-child),
  .faq-content :global(p + h2),
  .faq-content :global(ul + h2),
  .faq-content :global(ol + h2) {
    margin-top: var(--pl-space-sm, 0.75rem);
  }

  /* Tighten gap between question card and its first answer */
  .faq-content :global(h2 + p),
  .faq-content :global(h2 + ul),
  .faq-content :global(h2 + ol) {
    margin-top: 0;
  }

  /* Collapse bottom margin on paragraphs inside FAQ answers */
  .faq-content :global(p) {
    margin-bottom: var(--pl-space-sm, 0.75rem);
  }
</style>
