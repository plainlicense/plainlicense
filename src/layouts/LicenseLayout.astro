---
import type { LicenseEntryT } from "../_types/licenses";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  license: LicenseEntryT;
}

const { license } = Astro.props;
const { data } = license;

const spdxIdentifier = data.original?.spdx_id || data.spdx_id;
---

<BaseLayout
  title={data.plain_name}
  description={data.description}
>
  <main class="license-page" data-spdx-id={spdxIdentifier}>
    <header>
      <h1>{data.plain_name}</h1>
      <div class="metadata">
        <span class="spdx-id">{spdxIdentifier}</span>
        <span class="category">{data.license_family}</span>
        {
          data.plain_version && (
            <span class="version">v{data.plain_version}</span>
          )
        }
      </div>
    </header>

    <section class="summary">
      <p>{data.description}</p>
    </section>

    <div class="content-wrapper">
      <article class="prose"><slot /></article>

      <aside class="sidebar" aria-label="License details">
        {
          data.original?.permissions && (
            <section aria-label="Permissions">
              <h3>Permissions</h3>
              <ul>
                {data.original.permissions.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </section>
          )
        }
        {
          data.original?.conditions && (
            <section aria-label="Conditions">
              <h3>Conditions</h3>
              <ul>
                {data.original.conditions.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </section>
          )
        }
        {
          data.original?.limitations && (
            <section aria-label="Limitations">
              <h3>Limitations</h3>
              <ul>
                {data.original.limitations.map((l) => (
                  <li>{l}</li>
                ))}
              </ul>
            </section>
          )
        }
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
  .license-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 1rem;
  }
  .plain-name {
    font-size: 1.5rem;
    color: #aaa;
  }
  .metadata {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    color: #888;
  }
  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 250px;
    gap: 3rem;
  }
  .prose {
    line-height: 1.6;
  }
  aside section {
    margin-bottom: 1.5rem;
  }
  h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: #888;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    font-size: 0.9rem;
    margin-bottom: 0.3rem;
  }
</style>
