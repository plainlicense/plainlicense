---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV ? true : data.status === 'published';
})).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog" description="Latest news and updates from the Plain License team.">
  <header class="blog-header">
    <h1>Blog</h1>
    <p>Insights, updates, and guides on simplified software licensing.</p>
  </header>

  <main class="container">
    <div class="posts-grid">
      {posts.map(post => (
        <article class="post-card">
          {post.data.og_image && (
            <div class="post-image">
              <img src={post.data.og_image} alt="" />
            </div>
          )}
          <div class="post-content">
            <header>
              <div class="meta">
                <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}</time>
                {post.data.category && <span class="category">{post.data.category}</span>}
              </div>
              <h2><a href={`/blog/${post.slug || post.id}/`}>{post.data.title}</a></h2>
            </header>
            <p>{post.data.description}</p>
            <footer>
              <span class="author">By {post.data.author}</span>
              <a href={`/blog/${post.slug || post.id}/`} class="read-more">Read More →</a>
            </footer>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="no-posts">
        <p>No blog posts found. Check back soon!</p>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .blog-header {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(rgba(136, 58, 234, 0.1), transparent);
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .post-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    border-bottom: 1px solid #333;
    padding-bottom: 3rem;
  }
  @media (min-width: 768px) {
    .post-card {
      grid-template-columns: 300px 1fr;
    }
  }
  .post-card:last-child {
    border-bottom: none;
  }
  .post-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 8px;
    background: #1a1c23;
  }
  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 0.5rem;
  }
  .category {
    color: #883aea;
    text-transform: uppercase;
    font-weight: bold;
  }
  h2 {
    margin: 0 0 1rem 0;
    font-size: 1.75rem;
  }
  h2 a {
    color: white;
    text-decoration: none;
  }
  h2 a:hover {
    color: #883aea;
  }
  p {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
  }
  .author {
    color: #888;
  }
  .read-more {
    color: #883aea;
    text-decoration: none;
    font-weight: bold;
  }
  .no-posts {
    text-align: center;
    padding: 4rem;
    color: #888;
  }
</style>
