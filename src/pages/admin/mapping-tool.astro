---
import { getCollection } from "astro:content";
import MappingEditor from "../../components/MappingEditor";
import BaseLayout from "../../layouts/BaseLayout.astro";

const licenses = await getCollection("licenses");
const { searchParams } = Astro.url;
const selectedId = searchParams.get("id");

let license = null;
let originalText = "";

if (selectedId) {
  license = licenses.find((l) => l.id === selectedId);
  if (license) {
    // Extract original text from body or metadata
    // In our migration script, we combined them with ---
    const parts = license.body.split("---");
    // For prototype, let's assume first part is plain, second is original
    // In reality, we'd have more robust extraction
    originalText =
      parts[1]?.replace("# Original License Text", "")?.trim() ||
      "Original text not found.";
  }
}
---

<BaseLayout title="Mapping Tool">
  {!selectedId ? (
      <div class="selection-screen container">
        <h1>Select License to Map</h1>
        <div class="license-grid">
          {licenses.map((l) => (
            <a href={`?id=${l.id}`} class="card">
              {l.data.title}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="editor-screen">
        {license && (
          <MappingEditor
            client:only="preact"
            licenseId={license.id}
            plainText={license.body.split("---")[0]}
            originalText={originalText}
          />
        )}
      </div>
    )}
</BaseLayout>

<style>
.container {
  max-width: 800px;
  margin: 4rem auto;
  padding: 0 2rem;
}
.license-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.5rem;
  margin-top: 2rem;
}
.card {
  padding: 1.5rem;
  background: #1a1c23;
  border: 1px solid #333;
  border-radius: 8px;
  text-decoration: none;
  color: white;
  text-align: center;
}
.card:hover {
  border-color: #883aea;
}
</style>
