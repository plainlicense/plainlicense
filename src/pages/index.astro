---
import { FAMILY_ORDER } from "../data/license-families/index";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLicenseSlug, getPublishedLicenses } from "../utils/collections";
import "../assets/stylesheets/custom.css";

export const prerender = true;
const allLicenses = await getPublishedLicenses();
const licenses = [...allLicenses].sort((a, b) => {
  const aIdx = FAMILY_ORDER.indexOf(a.data.license_family);
  const bIdx = FAMILY_ORDER.indexOf(b.data.license_family);
  return (aIdx === -1 ? 99 : aIdx) - (bIdx === -1 ? 99 : bIdx);
});
const featuredLicenses = licenses.filter((l) => l.data.featured);
const MAX_INLINE_LICENSES = 8;
const hasMore = licenses.length > MAX_INLINE_LICENSES;
---

<BaseLayout
  title="Home"
  description="Plain License — simplified, human-readable versions of popular open source licenses."
>
  <div class="hero">
    <div class="hero-inner">
      <h1>Licenses you can actually understand</h1>
      <p class="hero-sub">
        Plain language rewrites of popular licenses — clear, accurate, and free
        to use.
      </p>
      <div class="hero-cta">
        <a href="/licenses/" class="btn-primary">Browse Licenses</a>
        <a href="/about/" class="btn-secondary">Learn more</a>
      </div>
    </div>
  </div>

  <div class="home-content">
    {featuredLicenses.length > 0 && (
      <section class="section">
        <h2 class="section-title">Featured Licenses</h2>
        <div class="card-grid">
          {featuredLicenses.map(license => (
            <a href={`/licenses/${getLicenseSlug(license)}/`} class={`card cat-${license.data.license_family}`}>
              <div class="card-badges">
                <span class="spdx-badge">{license.data.spdx_id}</span>
                {license.data.is_osi_approved && <span class="osi-badge">OSI ✓</span>}
              </div>
              <h3>{license.data.plain_name}</h3>
              <p>{license.data.description}</p>
              <span class="card-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section">
      <div class="all-licenses-header">
        <h2 class="section-title">All Licenses</h2>
        {hasMore && <a href="/licenses/" class="see-all">Explore all →</a>}
      </div>
      <ul class="license-list">
        {licenses.map(license => (
          <li class={`cat-${license.data.license_family}`}>
            <a href={`/licenses/${getLicenseSlug(license)}/`}>
              <span class="list-name">{license.data.plain_name}</span>
              <span class="list-spdx">{license.data.spdx_id}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="section how-it-works">
      <h2 class="section-title">How it works</h2>
      <div class="steps-grid">
        <div class="step">
          <span class="step-number">1</span>
          <h3>Pick a license</h3>
          <p>Browse our library of popular licenses, organized by family — public domain, permissive, copyleft, or source-available.</p>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>Read the plain version</h3>
          <p>Each license is rewritten at an 8th-grade reading level. No legal jargon, no confusion — just clear rights and responsibilities.</p>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>Use it in your project</h3>
          <p>Download in any format, copy the attribution template, and you're done. The original license still applies — we just make it understandable.</p>
        </div>
      </div>
    </section>

    <section class="section why-plain">
      <h2 class="section-title">Why plain language?</h2>
      <div class="value-grid">
        <div class="value-card">
          <svg class="value-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <h3>8th-grade reading level</h3>
          <p>The average American reads at an 8th-grade level. Most licenses require a college education. We bridge that gap.</p>
        </div>
        <div class="value-card">
          <svg class="value-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v15"/><path d="m5 12 7 8 7-8"/><circle cx="5" cy="6" r="3"/><circle cx="19" cy="6" r="3"/></svg>
          <h3>Legally grounded</h3>
          <p>Every plain license falls back to its original. You get clarity without sacrificing legal standing.</p>
        </div>
        <div class="value-card">
          <svg class="value-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <h3>Free and open</h3>
          <p>All our work is public domain. Use it, share it, build on it — no strings attached.</p>
        </div>
        <div class="value-card">
          <svg class="value-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <h3>Community driven</h3>
          <p>Writers, lawyers, and developers collaborate to make every license clear, accurate, and accessible.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
/* ── Hero ── */
.hero {
  padding: 5rem 1.5rem 4rem;
  text-align: center;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, rgba(var(--emerald-rgb), 0.12), transparent),
    radial-gradient(ellipse 60% 40% at 80% 60%, rgba(var(--zaffre-rgb, 13, 25, 163), 0.08), transparent);
  border-bottom: 1px solid var(--bg-border, #242836);
}

.hero-inner {
  max-width: 48rem;
  margin: 0 auto;
}

.hero h1 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.025em;
  margin: 0 0 1rem;
  color: var(--text, #e8eaf0);
}

.hero-sub {
  font-size: 1.2rem;
  color: var(--text-muted, #8b90a0);
  margin: 0 0 2rem;
  line-height: 1.6;
}

.hero-cta {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

/* ── Buttons ── */
.btn-primary {
  display: inline-flex;
  align-items: center;
  padding: 0.7rem 1.5rem;
  border-radius: 8px;
  background: var(--emerald);
  color: #0d0f15;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  transition:
    background 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.btn-primary:hover {
  background: var(--aquamarine);
  color: #0d0f15;
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(var(--emerald-rgb), 0.3);
}

.btn-primary:active {
  transform: translateY(0);
  box-shadow: 0 2px 8px rgba(var(--emerald-rgb), 0.2);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  padding: 0.7rem 1.5rem;
  border-radius: 8px;
  background: transparent;
  border: 1px solid var(--bg-border, #242836);
  color: var(--text-muted, #8b90a0);
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition:
    border-color 0.2s ease,
    color 0.2s ease,
    background 0.2s ease,
    transform 0.2s ease;
}

.btn-secondary:hover {
  border-color: rgba(var(--emerald-rgb), 0.5);
  color: var(--emerald);
  background: rgba(var(--emerald-rgb), 0.06);
  transform: translateY(-2px);
}

.btn-secondary:active {
  transform: translateY(0);
}

/* ── Layout ── */
.home-content {
  max-width: 72rem;
  margin: 0 auto;
  padding: 3rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 3.5rem;
}

.section-title {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 1.5rem;
  color: var(--text, #e8eaf0);
}

/* ── Featured Cards ── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}

.card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  padding-left: 1.75rem;
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  border-left: 3px solid var(--cat-color, var(--emerald));
  border-radius: 10px;
  text-decoration: none;
  color: var(--text, #e8eaf0);
  transition:
    border-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease,
    background 0.2s ease;
}

.card:hover {
  border-color: rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
  border-left-width: 4px;
  padding-left: calc(1.75rem - 1px);
  transform: translateY(-3px);
  box-shadow:
    0 6px 24px rgba(var(--cat-color-rgb, 21, 219, 149), 0.12),
    0 0 0 1px rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  background:
    radial-gradient(ellipse at top left, rgba(var(--cat-color-rgb, 21, 219, 149), 0.04), transparent 70%),
    var(--bg-surface, #161923);
  color: var(--text, #e8eaf0);
}

.card-arrow {
  display: block;
  margin-top: auto;
  padding-top: 0.75rem;
  font-size: 1rem;
  color: var(--cat-color, var(--emerald));
  opacity: 0;
  transform: translateX(-4px);
  transition:
    opacity 0.2s ease,
    transform 0.2s ease;
  text-align: right;
}

.card:hover .card-arrow {
  opacity: 0.7;
  transform: translateX(0);
}

.card-badges {
  display: flex;
  gap: 0.4rem;
  margin-bottom: 0.75rem;
}

.spdx-badge {
  font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
  font-size: 0.75rem;
  font-weight: 600;
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.12);
  color: var(--cat-color, var(--emerald));
  border: 1px solid rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
  border-radius: 4px;
  padding: 0.15em 0.5em;
}

.osi-badge {
  font-size: 0.7rem;
  font-weight: 600;
  color: #60a5fa;
  background: rgba(96, 165, 250, 0.1);
  border: 1px solid rgba(96, 165, 250, 0.3);
  border-radius: 4px;
  padding: 0.15em 0.4em;
}

.card h3 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  margin: 0 0 0.5rem;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--cat-color, var(--emerald));
}

.card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--text-muted, #8b90a0);
  line-height: 1.5;
}

/* ── All Licenses List ── */
.all-licenses-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.all-licenses-header .section-title {
  margin-bottom: 0;
}

.see-all {
  font-size: 0.9rem;
  color: var(--emerald);
  text-decoration: none;
  font-weight: 500;
  transition:
    color 0.15s ease,
    gap 0.15s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.15em;
}

.see-all:hover {
  color: var(--aquamarine);
  gap: 0.4em;
}

.license-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 0.5rem;
}

.license-list li a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 0.75rem;
  padding-left: 1rem;
  border-radius: 6px;
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  border-left: 3px solid var(--cat-color, var(--emerald));
  text-decoration: none;
  transition:
    border-color 0.2s ease,
    background 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.license-list li a:hover {
  border-color: rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
  border-left-color: var(--cat-color, var(--emerald));
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.04);
  transform: translateX(2px);
  box-shadow: 0 2px 8px rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  color: var(--text, #e8eaf0);
}

.list-name {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text, #e8eaf0);
}

.list-spdx {
  font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
  font-size: 0.7rem;
  color: var(--text-muted, #8b90a0);
}

/* ── How It Works ── */
.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 2rem;
}

.step {
  position: relative;
  padding: 1.5rem;
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  border-radius: 10px;
  transition:
    border-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.step:hover {
  border-color: rgba(var(--emerald-rgb), 0.2);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(var(--emerald-rgb), 0.06);
}

.step-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  background: var(--emerald);
  color: #0d0f15;
  font-weight: 800;
  font-size: 0.85rem;
  margin-bottom: 0.75rem;
}

.step h3 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
  color: var(--text, #e8eaf0);
}

.step p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--text-muted, #8b90a0);
  line-height: 1.55;
}

/* ── Why Plain Language ── */
.value-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}

.value-card {
  padding: 1.25rem;
  border-radius: 10px;
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  transition:
    border-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.value-card:hover {
  border-color: rgba(var(--emerald-rgb), 0.2);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(var(--emerald-rgb), 0.06);
}

.value-icon {
  width: 1.75rem;
  height: 1.75rem;
  display: block;
  margin-bottom: 0.75rem;
  color: var(--emerald);
  transition: transform 0.2s ease;
}

.value-card:hover .value-icon {
  transform: scale(1.1);
}

.value-card h3 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: 0.95rem;
  font-weight: 700;
  margin: 0 0 0.4rem;
  color: var(--text, #e8eaf0);
}

.value-card p {
  margin: 0;
  font-size: 0.85rem;
  color: var(--text-muted, #8b90a0);
  line-height: 1.5;
}
</style>
