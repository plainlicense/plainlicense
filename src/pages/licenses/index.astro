---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLicenseSlug, getPublishedLicenses } from "../../utils/collections";
import "../../assets/stylesheets/custom.css";

export const prerender = true;
const licenses = await getPublishedLicenses();

const byFamily = licenses.reduce<Record<string, typeof licenses>>(
  (acc, l) => {
    const fam = l.data.license_family;
    if (!acc[fam]) acc[fam] = [];
    acc[fam].push(l);
    return acc;
  },
  {},
);

const familyOrder = [
  "public-domain",
  "permissive",
  "copyleft",
  "source-available",
  "proprietary",
];
const familyLabels: Record<string, string> = {
  "public-domain": "Public Domain",
  permissive: "Permissive",
  copyleft: "Copyleft",
  "source-available": "Source Available",
  proprietary: "Proprietary",
};
const familyDescriptions: Record<string, string> = {
  "public-domain": "No rights reserved — use any way you want.",
  permissive: "Few restrictions — use freely in almost any project.",
  copyleft: "Share-alike — changes must stay under the same license.",
  "source-available": "Source visible but with usage restrictions.",
  proprietary: "All rights reserved — usage governed by specific terms.",
};
---

<BaseLayout
  title="All Licenses"
  description="Browse all Plain License plain-language rewrites of popular software licenses."
>
  <div class="licenses-page">
    <header class="page-header">
      <h1>All Licenses</h1>
      <p class="lead">
        Plain-language rewrites of popular software licenses, organized by family.
      </p>
      <p class="page-count">
        {licenses.length} licenses across {familyOrder.filter(fam => byFamily[fam]?.length).length} families
      </p>
    </header>

    <div class="categories">
      {familyOrder.filter(fam => byFamily[fam]?.length).map(fam => (
        <section class={`category-section cat-${fam}`} id={fam} key={fam}>
          <div class="category-header">
            <span class="category-pill">{familyLabels[fam]}</span>
            <p>{familyDescriptions[fam]}</p>
          </div>
          <div class="license-grid">
            {byFamily[fam].map(license => (
              <a href={`/licenses/${getLicenseSlug(license)}/`} class="license-card" key={license.data.spdx_id}>
                <div class="card-top">
                  <span class="spdx-badge">{license.data.spdx_id}</span>
                  {license.data.is_osi_approved && <span class="osi-badge" title="OSI Approved">OSI ✓</span>}
                </div>
                <h3>{license.data.plain_name}</h3>
                <p>{license.data.description}</p>
                {license.data.summary && (
                  <div class="summary">{license.data.summary}</div>
                )}
                <span class="card-arrow" aria-hidden="true">&rarr;</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.licenses-page {
  max-width: 72rem;
  margin: 0 auto;
  padding: 3rem 1.5rem;
}

/* ── Page Header ── */
.page-header {
  margin-bottom: 3.5rem;
  padding: 2.5rem 2rem 2rem;
  border-radius: 12px;
  background:
    linear-gradient(135deg, rgba(var(--emerald-rgb), 0.06) 0%, transparent 60%),
    linear-gradient(225deg, rgba(var(--zaffre-rgb), 0.10) 0%, transparent 50%),
    var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
}

.page-header h1 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: 2.75rem;
  font-weight: 800;
  margin: 0 0 0.5rem;
  color: var(--text, #e8eaf0);
  letter-spacing: -0.02em;
}

.lead {
  font-size: 1.15rem;
  color: var(--text-muted, #8b90a0);
  margin: 0;
}

.page-count {
  margin: 0.75rem 0 0;
  font-size: 0.8rem;
  font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
  color: var(--emerald);
  opacity: 0.7;
}

/* ── Categories ── */
.categories {
  display: flex;
  flex-direction: column;
  gap: 3.5rem;
}

/* ── Category Header ── */
.category-header {
  margin-bottom: 1.5rem;
  padding-left: 0.25rem;
}

.category-pill {
  display: inline-block;
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--cat-color, var(--emerald));
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.1);
  border: 1px solid rgba(var(--cat-color-rgb, 21, 219, 149), 0.25);
  border-radius: 6px;
  padding: 0.3em 0.75em;
  margin-bottom: 0.5rem;
}

.category-header p {
  margin: 0;
  padding-left: 0.15rem;
  color: var(--text-muted, #8b90a0);
  font-size: 0.95rem;
}

/* ── License Grid ── */
.license-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}

/* ── License Card ── */
.license-card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  padding-left: 1.75rem;
  background: var(--bg-surface, #161923);
  border: 1px solid var(--bg-border, #242836);
  border-left: 3px solid var(--cat-color, var(--emerald));
  border-radius: 10px;
  text-decoration: none;
  color: var(--text, #e8eaf0);
  transition:
    border-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease,
    background 0.2s ease;
}

.license-card:hover {
  border-color: rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
  border-left-width: 4px;
  padding-left: calc(1.75rem - 1px); /* compensate for wider border */
  transform: translateY(-3px);
  box-shadow:
    0 6px 24px rgba(var(--cat-color-rgb, 21, 219, 149), 0.12),
    0 0 0 1px rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  background:
    radial-gradient(ellipse at top left, rgba(var(--cat-color-rgb, 21, 219, 149), 0.04), transparent 70%),
    var(--bg-surface, #161923);
  color: var(--text, #e8eaf0);
}

/* ── Card Inner Elements ── */
.card-top {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.spdx-badge {
  font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
  font-size: 0.75rem;
  font-weight: 600;
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.12);
  color: var(--cat-color, var(--emerald));
  border: 1px solid rgba(var(--cat-color-rgb, 21, 219, 149), 0.3);
  border-radius: 4px;
  padding: 0.15em 0.5em;
}

.osi-badge {
  font-size: 0.7rem;
  font-weight: 600;
  color: #60a5fa;
  background: rgba(96, 165, 250, 0.1);
  border: 1px solid rgba(96, 165, 250, 0.3);
  border-radius: 4px;
  padding: 0.15em 0.4em;
}

.license-card h3 {
  font-family: var(--font-heading, "Plus Jakarta Sans", sans-serif);
  margin: 0 0 0.5rem;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--cat-color, var(--emerald));
}

.license-card p {
  margin: 0 0 0.5rem;
  font-size: 0.9rem;
  color: var(--text-muted, #8b90a0);
  line-height: 1.5;
}

.license-card p:last-of-type {
  margin-bottom: 0;
}

/* ── Summary Block ── */
.summary {
  font-style: italic;
  font-size: 0.85rem;
  color: var(--text-muted, #8b90a0);
  line-height: 1.5;
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.04);
  border-radius: 6px;
  padding: 0.6rem 0.75rem;
  margin-top: 0.75rem;
}

/* ── Card Arrow ── */
.card-arrow {
  display: block;
  margin-top: auto;
  padding-top: 0.75rem;
  font-size: 1rem;
  color: var(--cat-color, var(--emerald));
  opacity: 0;
  transform: translateX(-4px);
  transition:
    opacity 0.2s ease,
    transform 0.2s ease;
  text-align: right;
}

.license-card:hover .card-arrow {
  opacity: 0.7;
  transform: translateX(0);
}

/* ── Responsive ── */
@media (max-width: 480px) {
  .page-header {
    padding: 1.5rem 1.25rem;
  }
  .page-header h1 {
    font-size: 2rem;
  }
}
</style>
