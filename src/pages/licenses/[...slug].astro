---
import { getCollection } from "astro:content";
import "../../assets/stylesheets/custom.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LicenseLayout from "../../components/license/LicenseLayout.astro";
import { marked } from "marked";
import ComparisonModal from "../../components/ComparisonModal.astro";
import ComparisonToggle from "../../components/ComparisonToggle.astro";
import ReadabilitySidebar from "../../components/license/ReadabilitySidebar.astro";
import { ICONS } from "../../components/license/icons";
import DownloadOptions from "../../components/DownloadOptions.astro";
import VersionHistory from "../../components/VersionHistory.astro";
import NotLegalAdvice from "../../components/NotLegalAdvice.astro";
import { getLicenseSlug, getPublishedLicenses } from "../../utils/collections";
import { buildOriginalTextSeparator, stripComponentPlaceholders } from "../../utils/templates";
import { prepareFootnotes } from "../../utils/footnotes";
import "../../assets/stylesheets/footnotes.css";
import FootnoteScript from "../../components/FootnoteScript.astro";

export const prerender = true;
/**
 * Render markdown content, correctly handling <div id="..."> wrappers.
 *
 * CommonMark treats <div> as an HTML block and does NOT process markdown
 * inside it. This function splits on those wrappers, renders the inner
 * markdown independently, then re-wraps in the original <div id="...">.
 * This preserves the element IDs that MappingViewer needs.
 *
 * Limitation: the regex matches non-nested <div id="..."> blocks only.
 * Nested divs are not supported and should not appear in license content.
 */
/**
 * Convert mkdocs-style definition lists to semantic HTML <dl> blocks.
 *
 * Recognises two patterns (with optional blank line between term and definition):
 *   `term`           OR   `term` and `alias`
 *   :    Definition        :    Definition
 */
function convertDefinitionLists(md: string): string {
  // Match a ## Definitions heading followed by consecutive definition entries
  const sectionPattern = /(## Definitions\n)([\s\S]*?)(?=\n##\s|\n\{\{block:|\n---|\n$)/g;

  return md.replace(sectionPattern, (_match, heading: string, body: string) => {
    const entries: { term: string; definition: string }[] = [];
    // Split into blocks separated by blank lines, then pair terms with definitions
    const lines = body.split("\n");
    let i = 0;

    while (i < lines.length) {
      const line = lines[i].trim();
      // Match a term line: `term` or `term` and `alias`
      const termMatch = line.match(/^`([^`]+)`(?:\s+and\s+`([^`]+)`)?$/);
      if (termMatch) {
        const term = termMatch[2]
          ? `${termMatch[1]} / ${termMatch[2]}`
          : termMatch[1];
        // Look ahead for the definition line (skip blank lines)
        i++;
        while (i < lines.length && lines[i].trim() === "") i++;
        if (i < lines.length && lines[i].trim().startsWith(":")) {
          const def = lines[i].trim().replace(/^:\s+/, "");
          entries.push({ term, definition: def });
        }
      }
      i++;
    }

    if (entries.length === 0) return heading + body;

    const dlHtml = entries
      .map(
        (e) =>
          `<dt>${e.term}</dt>\n<dd>${e.definition}</dd>`,
      )
      .join("\n");

    return `${heading}\n<dl class="license-definitions">\n${dlHtml}\n</dl>\n\n`;
  });
}

/** Convert PyMdown `^^text^^` (caret) syntax to `<ins>` elements. */
function convertCaretInsert(md: string): string {
  return md.replace(/\^\^((?:[^^]|\^(?!\^))+?)\^\^/g, "<ins>$1</ins>");
}

function renderMarkdownWithDivs(md: string): string {
  // Pre-process mkdocs extensions before marked sees them
  const processed = convertCaretInsert(convertDefinitionLists(md));

  // Regex: <div id="X"> ... </div>  (non-nested, one per section)
  const divPattern = /<div id="([^"]+)">([\s\S]*?)<\/div>/g;
  let result = "";
  let lastIndex = 0;
  let match: RegExpExecArray | null = divPattern.exec(processed);

  while (match !== null) {
    // Render any content before this div block
    if (match.index > lastIndex) {
      result += marked.parse(processed.slice(lastIndex, match.index)) as string;
    }
    // Render the inner markdown and wrap in the div with its ID
    const innerHtml = marked.parse(match[2].trim()) as string;
    result += `<div id="${match[1]}">${innerHtml}</div>\n`;
    lastIndex = match.index + match[0].length;
    match = divPattern.exec(processed);
  }

  // Render any trailing content after the last div
  if (lastIndex < processed.length) {
    result += marked.parse(processed.slice(lastIndex)) as string;
  }

  return result;
}

export async function getStaticPaths() {
  const licenses = await getPublishedLicenses();
  console.log("Generating paths for", licenses.length, "licenses");

  return licenses.map((license) => {
    const slug = getLicenseSlug(license);
    console.log(" - Path:", `/licenses/${slug}`);
    return {
      params: { slug },
      props: { license },
    };
  });
}

const { license } = Astro.props;
const { data } = license;

// Extract original license text from markdown body (after separator)
const bodyParts = license.body.split(/---[\s\n]+# Original License Text/i);
const originalBody = bodyParts.length > 1 ? bodyParts[1] : "";

// Build processed body for clipboard/export (plain text from body + original text)
const templateBlocks = await getCollection("templateBlocks");
const plainBody = bodyParts[0].replace(
  /{{block:([a-z0-9-]+)}}/g,
  (_match, blockId) => {
    const block = templateBlocks.find(
      (b) =>
        b.id === blockId ||
        b.id.split("/").pop()?.replace(/\.md$/, "") === blockId,
    );
    return block ? block.body : `[Missing Block: ${blockId}]`;
  },
);
// Resolve {{var:...}} placeholders from frontmatter
const templateVars: Record<string, string> = {
  plain_name: data.plain_name || "",
  original_name: data.original?.name || "",
  original_version_name: data.original?.version_display || data.original?.name || "",
  license_type: data.is_dedication ? "dedication" : "license",
};
const resolvedBody = plainBody.replace(
  /\{\{var:([a-z_]+)\}\}/g,
  (_m, key) => templateVars[key] ?? "",
);

const fullProcessedBody = stripComponentPlaceholders(
  resolvedBody +
  (originalBody ? buildOriginalTextSeparator() + originalBody : "")
).trim();

// For the full text view: use the fully processed body (blocks resolved, vars replaced, components stripped)
// Split off any original text that was appended for the clipboard version
const fullTextBody = stripComponentPlaceholders(resolvedBody);
const { cleaned: fnCleanedBody, postProcess: fnPostProcess } = prepareFootnotes(fullTextBody);
const renderedPlainHtml = fnPostProcess(renderMarkdownWithDivs(fnCleanedBody));

// The fullProcessedBody (used for clipboard) has blocks resolved via the export pipeline,
// but the in-page rendering uses resolvedBody which may have unresolved blocks if
// getCollection("template-blocks") returns IDs that don't match.

// Readability data for the full text tab
const plain_gunning_fog = data.plain_gunning_fog;
const original_gunning_fog = data.original?.original_gunning_fog;
const shame_words_count = data.shame_words_count;
const hasData = plain_gunning_fog !== undefined || shame_words_count !== undefined;
const hasComparison = plain_gunning_fog !== undefined && original_gunning_fog !== undefined;
const improvement = hasComparison
  ? parseFloat((original_gunning_fog! - plain_gunning_fog!).toFixed(1))
  : undefined;

function readabilityLevel(score: number): string {
  if (score <= 6) return "6th grade";
  if (score <= 8) return "8th grade";
  if (score <= 10) return "10th grade";
  if (score <= 12) return "High school";
  if (score <= 14) return "College";
  return "Post-graduate";
}
---

<BaseLayout title={data.plain_name}>
  <div class={`license-container cat-${data.license_family}`} data-spdx-id={data.spdx_id}>

    <!-- Tab navigation -->
    <nav class="license-tabs" role="tablist" aria-label="License view">
      <button role="tab" id="tab-reference" aria-controls="panel-reference" aria-selected="true" class="tab-button active" tabindex="0">
        Quick Reference
      </button>
      <button role="tab" id="tab-fulltext" aria-controls="panel-fulltext" aria-selected="false" class="tab-button" tabindex="-1">
        Full License Text
      </button>
    </nav>

    <!-- Quick Reference panel (zone-based view) -->
    <div id="panel-reference" role="tabpanel" aria-labelledby="tab-reference" class="tab-panel active">
      <LicenseLayout license={license} />
    </div>

    <!-- Full License Text panel -->
    <div id="panel-fulltext" role="tabpanel" aria-labelledby="tab-fulltext" class="tab-panel" hidden>
      {data.has_mapping && (
        <div id="comparison-toggle-wrapper" hidden>
          <ComparisonToggle hasMapping={true} />
        </div>
      )}
      {/* Readability comparison bar — columns align with plain/original license text */}
      {hasData && (
        <div class="fulltext-readability" role="region" aria-label="Readability scores">
          <div class="readability-bar">
            {/* Plain license stats — left side, aligns with plain column */}
            <div class="bar-side bar-side--plain">
              <svg class="readability-bar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS["bar-chart"]} />
              {plain_gunning_fog !== undefined && (
                <span class="bar-stat">
                  <span class="bar-stat-label">Plain</span>
                  <span class="bar-stat-score bar-score--plain">{plain_gunning_fog}</span>
                  <span class="bar-stat-level">{readabilityLevel(plain_gunning_fog)}</span>
                </span>
              )}
              {shame_words_count !== undefined && (
                <span class="bar-shame">
                  <span class="bar-shame-count">{shame_words_count}</span> jargon
                </span>
              )}
            </div>

            {/* Improvement badge — center */}
            {improvement !== undefined && improvement > 0 && (
              <div class="bar-center">
                <span class="bar-improvement">↓ {improvement} grades easier</span>
              </div>
            )}

            {/* Original license stats — right side, aligns with original column */}
            {hasComparison && (
              <div class="bar-side bar-side--original">
                <span class="bar-stat">
                  <span class="bar-stat-label">Original</span>
                  <span class="bar-stat-score bar-score--original">{original_gunning_fog}</span>
                  <span class="bar-stat-level">{readabilityLevel(original_gunning_fog!)}</span>
                </span>
              </div>
            )}
          </div>
        </div>
      )}

      <div class="license-layout">
        <div class="license-column plain-version">
          <div class="column-badge column-badge--plain">
            <svg class="column-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
            Plain Language
          </div>
          <article class="full-license-text prose" set:html={renderedPlainHtml} />
        </div>
        {data.show_original_comparison !== false && originalBody && (
          <div class="license-column original-version">
            <div class="column-badge column-badge--original">
              <svg class="column-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" />
              </svg>
              Original
            </div>
            <h2 class="original-heading">{data.original?.name ?? "Original License"}</h2>
            <div class="license-content prose" set:html={renderMarkdownWithDivs(originalBody)} />
          </div>
        )}
      </div>
    </div>

    <DownloadOptions license={license} processedBody={fullProcessedBody} />

    <div class="reference-fold" aria-hidden="true">
      <span class="fold-rule"></span>
      <span class="fold-note">Reference</span>
      <span class="fold-rule"></span>
    </div>

    <div class="reference-section">
      <ReadabilitySidebar
        plain_gunning_fog={data.plain_gunning_fog}
        original_gunning_fog={data.original?.original_gunning_fog}
        shame_words_count={data.shame_words_count}
      />
      <VersionHistory license={license} />
      <NotLegalAdvice />
    </div>
    <ComparisonModal />
  </div>
  <FootnoteScript />
</BaseLayout>

<script>
  import { initMappingViewer } from "../../components/MappingViewer";

const container = document.querySelector(".license-container") as HTMLElement;
const spdxId = container?.dataset.spdxId;

if (spdxId) {
  fetch(`/mappings/${spdxId}-mapping.json`)
    .then((res) => {
      if (!res.ok) throw new Error(`Failed to fetch mapping: HTTP ${res.status} for /mappings/${spdxId}-mapping.json`);
      return res.json() as Promise<Parameters<typeof initMappingViewer>[0]>;
    })
    .then((mappingData) => {
      const wrapper = document.getElementById("comparison-toggle-wrapper");
      if (wrapper) wrapper.hidden = false;
      initMappingViewer(mappingData);
    })
    .catch(() => {
      console.log(`No mapping found for ${spdxId}`);
    });
}

// Tab switching
const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => {
      t.setAttribute('aria-selected', 'false');
      t.classList.remove('active');
      t.tabIndex = -1;
    });
    panels.forEach(p => {
      p.hidden = true;
      p.classList.remove('active');
    });
    tab.setAttribute('aria-selected', 'true');
    tab.classList.add('active');
    tab.tabIndex = 0;
    const panelId = tab.getAttribute('aria-controls');
    if (panelId) {
      const panel = document.getElementById(panelId);
      if (panel) {
        panel.hidden = false;
        panel.classList.add('active');
      }
    }
    // Hide the reference-section readability card when fulltext tab is active
    // (fulltext has its own inline readability bar, so showing both is redundant)
    container?.classList.toggle('fulltext-active', panelId === 'panel-fulltext');

    // Coordinate comparison-active class with active tab
    const compToggle = document.getElementById("comparison-toggle") as HTMLButtonElement | null;
    if (panelId === 'panel-fulltext') {
      if (compToggle?.getAttribute('aria-pressed') === 'true') {
        container?.classList.add('comparison-active');
      }
    } else {
      container?.classList.remove('comparison-active');
    }
  });

  tab.addEventListener('keydown', (e: KeyboardEvent) => {
    const tabList = Array.from(tabs);
    const idx = tabList.indexOf(tab);
    let target: HTMLButtonElement | undefined;
    if (e.key === 'ArrowRight') target = tabList[(idx + 1) % tabList.length];
    if (e.key === 'ArrowLeft') target = tabList[(idx - 1 + tabList.length) % tabList.length];
    if (target) {
      e.preventDefault();
      target.focus();
      target.click();
    }
  });
});
</script>

<style>
.license-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
  transition: max-width 0.3s ease;
}

/* ── Tabs ── */
.license-tabs {
  display: flex;
  gap: 0;
  border-bottom: 2px solid var(--sl-color-gray-5);
  margin-bottom: 2rem;
}

.tab-button {
  padding: 0.75rem 1.5rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  color: var(--sl-color-gray-3);
  font-weight: 600;
  font-size: var(--sl-text-sm);
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
}

.tab-button:hover {
  color: var(--sl-color-gray-1);
}

.tab-button.active {
  color: var(--cat-color, var(--sl-color-accent));
  border-bottom-color: var(--cat-color, var(--sl-color-accent));
}

.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}

/* ── Full License Text ── */
.full-license-text {
  max-width: 65ch;
  font-size: var(--sl-text-base);
  line-height: 1.8;
  color: var(--sl-color-gray-1);
}

.full-license-text :global(h1) {
  font-size: 1.75rem;
  font-weight: 800;
  color: var(--sl-color-white);
  margin: 0 0 1.5rem 0;
  line-height: 1.3;
}

.full-license-text :global(h2) {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--sl-color-white);
  margin: 2rem 0 1rem 0;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--sl-color-gray-5);
}

.full-license-text :global(h3) {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--sl-color-gray-1);
  margin: 1.5rem 0 0.75rem 0;
}

.full-license-text :global(p) {
  margin: 0 0 1rem 0;
}

.full-license-text :global(ul),
.full-license-text :global(ol) {
  margin: 0 0 1rem 0;
  padding-left: 1.5rem;
}

.full-license-text :global(li) {
  margin-bottom: 0.5rem;
}

.full-license-text :global(code) {
  background: var(--sl-color-gray-6);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 4px;
  padding: 0.1em 0.35em;
  font-size: 0.85em;
}

.full-license-text :global(strong) {
  color: var(--sl-color-white);
}

.full-license-text :global(a) {
  color: var(--cat-color, var(--sl-color-accent));
  text-underline-offset: 2px;
}

/* ── Zone layout ── */
.license-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

.original-version {
  display: none;
  opacity: 0.6;
  transition: opacity 0.3s;
}

.original-version:hover {
  opacity: 1;
}

@media (min-width: 1024px) {
  .license-layout {
    gap: 4rem;
  }

  .comparison-active .license-layout {
    grid-template-columns: 1fr 1fr;
  }

  .comparison-active .original-version {
    display: block;
  }

  .comparison-active.license-container {
    max-width: 1400px;
  }
}

.license-content {
  line-height: 1.6;
}

/* ── Reference fold ── */
.reference-fold {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin: 3rem 0 2rem;
}

.fold-rule {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--sl-color-gray-4), transparent);
}

.fold-note {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-4);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  white-space: nowrap;
}

.reference-section {
  padding: 2rem;
  background: var(--sl-color-gray-7, #0d0f15);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 12px;
}

.comparison-active .license-content [id] {
  cursor: pointer;
  position: relative;
  border-radius: 4px;
  transition: background-color 0.2s;
}

@media (max-width: 1023px) {
  .comparison-active .license-content [id]:active {
    background-color: rgba(var(--sl-color-accent-rgb), 0.1);
  }
}

.comparison-active .license-content [id]:hover {
  background-color: rgba(var(--sl-color-accent-rgb), 0.05);
}

:global(.highlight-active) {
  background-color: rgba(var(--sl-color-accent-rgb), 0.2);
  border-radius: 4px;
  box-shadow: 0 0 0 4px rgba(var(--sl-color-accent-rgb), 0.2);
  transition: all 0.2s ease;
}

:global(.highlight-match) {
  background-color: rgba(var(--sl-color-accent-rgb), 0.1);
  border-radius: 4px;
  box-shadow: 0 0 0 4px rgba(var(--sl-color-accent-rgb), 0.1);
  transition: all 0.2s ease;
}

/* ── Column badges ── */
.column-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  font-size: var(--sl-text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 1rem;
}

.column-badge-icon {
  width: 0.85rem;
  height: 0.85rem;
  flex-shrink: 0;
}

.column-badge--plain {
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.12);
  color: var(--cat-color, var(--sl-color-accent));
  border: 1px solid rgba(var(--cat-color-rgb, 21, 219, 149), 0.25);
}

.column-badge--original {
  background: rgba(var(--sl-color-gray-3-rgb, 155, 155, 155), 0.1);
  color: var(--sl-color-gray-2);
  border: 1px solid var(--sl-color-gray-5);
}

/* ── Fulltext readability bar ── */
.fulltext-readability {
  margin-bottom: 1.5rem;
}

.readability-bar {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.6rem 1.25rem;
  background: var(--sl-color-gray-6);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 8px;
  flex-wrap: wrap;
}

.bar-side {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.bar-side--original {
  margin-left: auto;
}

.bar-center {
  display: flex;
  align-items: center;
}

.readability-bar-icon {
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
  color: var(--cat-color, var(--sl-color-accent));
}

.bar-stat {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  font-size: var(--sl-text-sm);
}

.bar-stat-label {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
  font-weight: 500;
}

.bar-stat-score {
  font-weight: 700;
}

.bar-score--plain {
  color: var(--cat-color, var(--sl-color-accent));
}

.bar-score--original {
  color: var(--sl-color-gray-2);
}

.bar-stat-level {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
}

.bar-improvement {
  font-size: var(--sl-text-xs);
  font-weight: 600;
  color: var(--cat-color, var(--sl-color-accent));
  background: rgba(var(--cat-color-rgb, 21, 219, 149), 0.08);
  padding: 0.2rem 0.6rem;
  border-radius: 99px;
  white-space: nowrap;
}

.bar-shame {
  font-size: var(--sl-text-xs);
  color: var(--sl-color-gray-3);
}

.bar-shame-count {
  font-weight: 700;
  color: var(--sl-color-gray-1);
}

/* Comparison mode: readability bar becomes a 3-column grid matching the license columns */
@media (min-width: 1024px) {
  .comparison-active .readability-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: nowrap;
  }

  .comparison-active .bar-side--plain {
    justify-self: start;
  }

  .comparison-active .bar-center {
    justify-self: center;
  }

  .comparison-active .bar-side--original {
    justify-self: end;
    margin-left: 0;
  }
}

/* Hide reference-section readability card when fulltext tab is active (it has its own inline bar) */
.fulltext-active :global(.readability-card) {
  display: none;
}

/* ── Insert/underline emphasis (^^text^^) ── */
.full-license-text :global(ins) {
  text-decoration: none;
  background: linear-gradient(
