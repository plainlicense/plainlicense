{
  "$schema": "node_modules/wrangler/config-schema.json",
  "account_id": "1bb2d128ac96f8ee9dc75e99a54e9260",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "compatibility_date": "2026-03-29",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "images": {
    "binding": "IMAGES",
    "remote": true
  },
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "plainlicense-cms-admin",
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "preview_urls": true,
  "routes": [
    {
      "custom_domain": true,
      "pattern": "admin.plainlicense.org"
    }
  ],
  "secrets_store_secrets": [
    {
      "binding": "S3_SECRET_KEY",
      "secret_name": "PL_S3_SECRET_KEY",
      "store_id": "98acd7f077774ecfb34a31ac8cce6c98"
    },
    {
      "binding": "TURNSTILE_SECRET_KEY",
      "secret_name": "TURNSTILE_SECRET_KEY",
      "store_id": "98acd7f077774ecfb34a31ac8cce6c98"
    }
  ],
  "vars": {
    "S3_ACCESS_KEY": "2af46c19f417f0b062f540805412da84",
    "TURNSTILE_SITE_KEY": "0x4AAAAAAC0oYIe6F8T0nJHd"
  },
  "workers_dev": true
}
