{
  "[astro]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.ts": "always"
    },
    "editor.defaultFormatter": "astro-build.astro-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "files.autoSave": "onFocusChange"
  },
  "[css]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.stylelint": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true
  },
  "[html]": {
    "editor.autoIndent": "advanced",
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.html": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[javascript]": {
    "editor.codeActions.triggerOnFocusChange": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.eslint": "always",
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.formatOnType": false,
    "editor.maxTokenizationLineLength": 10000,
    "editor.pasteAs.preferences": [],
    "files.autoSave": "onFocusChange"
  },
  "[json]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.sortJSON": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.sortJSON": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 2,
    "editor.wordBasedSuggestions": "matchingDocuments",
    "files.eol": "\n"
  },
  "[pkl]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.defaultFormatter": "Pkl.pkl-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 4,
    "files.eol": "\n"
  },
  "[python]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.wordBasedSuggestions": "matchingDocuments"
  },
  "[shellscript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.fixAll.shellcheck": "always"
    },
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 4,
    "files.eol": "\n"
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.addMissingImports.ts": "always",
      "source.fixAll": "always",
      "source.fixAll.eslint": "always",
      "source.fixAll.ts": "always",
      "source.organizeImports": "always",
      "source.organizeImports.ts": "always"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.formatOnType": false,
    "files.autoSave": "onFocusChange"
  },
  "[yaml]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.autoIndent": "keep",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnType": true,
    "editor.insertSpaces": true,
    "editor.quickSuggestions": {
      "comments": false,
      "other": true,
      "strings": true
    },
    "editor.tabSize": 2
  },
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.includePackageJsonAutoImports": "auto",
  "js/ts.updateImportsOnPaste.enabled": true,
  "js/ts.tsserver.automaticTypeAcquisition.enabled": true,
  "editor.fontFamily": "'Fira Code Retina', 'FiraCode-Retina', 'Fira Code', 'Source Code Pro', 'Droid Sans Mono', 'monospace', 'Droid Sans Fallback'",
  "editor.fontLigatures": "'cv19', 'cv24', 'cv27', 'cv30', 'ss02', 'ss07', 'ss08', 'ss09', 'zero'",
  "editor.fontWeight": "450",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "git.allowNoVerifyCommit": true,
  "git.autoStash": true,
  "git.autofetch": true,
  "git.branchRandomName.enable": true,
  "git.closeDiffOnOperation": true,
  "git.confirmSync": false,
  "git.countBadge": "tracked",
  "git.enableSmartCommit": true,
  "git.ignoreSubmodules": true,
  "git.openRepositoryInParentFolders": "always",
  "git.replaceTagsWhenPull": true,
  "git.terminalGitEditor": true,
  "git.useCommitInputAsStashMessage": true,
  "github.copilot.enable": {
    "css": true,
    "go": true,
    "handlebars": true,
    "html": true,
    "java": true,
    "javascript": true,
    "javascriptreact": true,
    "json": true,
    "less": true,
    "markdown": true,
    "plaintext": false,
    "python": true,
    "rust": true,
    "sass": true,
    "scss": true,
    "swift": true,
    "typescript": true,
    "typescriptreact": true,
    "vb": true,
    "vue": true,
    "vue-html": true,
    "yaml": true
  },
  "npm.fetchOnlinePackageInfo": true,
  "npm.packageManager": "bun",
  "npm.scriptRunner": "bun",
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.pythonProjects": [],
  "python.languageServer": "Pylance",
  "terminal.integrated.fontFamily": "monospace",
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "/home/knitli/.local/share/mise/shims/node"
  },
  "shellcheck.executablePath": "/home/knitli/.local/share/mise/shims/shellcheck",
  "ruff.path": ["/home/knitli/.local/share/mise/shims/ruff"],
  "python.defaultInterpreterPath": "/home/knitli/.local/share/mise/installs/python/3.14.3/bin/python",
  "ruff.interpreter": ["/home/knitli/.local/share/mise/shims/python"]
}
