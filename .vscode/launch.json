{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach Firefox Debug",
      "type": "firefox",
      "clearConsoleOnReload": true,
      "request": "attach",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/src",
      "reloadOnAttach": true,
      "port": 6000,
      "preLaunchTask": "mkdocs serve live",
      "skipFiles": [
        "${workspaceFolder}/node_modules/**/*",
        "${workspaceFolder}/external/**/*"
      ],
      "pathMappings": [
        {
          "url": "/",
          "path": "${workspaceFolder}/docs"
        }
      ]
    },
    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "preLaunchTask": "prepare-chrome",
      "pathMapping": {
        "/": "${workspaceFolder}/docs"
      },
      "runtimeExecutable": "/usr/bin/flatpak run --branch=stable --arch=x86_64 --command=/app/bin/chromium --enable-features=UseOzonePlatform --ozone-platform=wayland --gtk-version=4 --gpu-testing-vendor-id=0x10de --gpu-testing-device-id=0x25ac",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/docs/**",
        "!**/node_modules/**"
      ],
      "smartStep": true,
      "skipFiles": [
        "**/node_modules/**",
        "${workspaceFolder}/external/**"
      ]
    },
    {
      "name": "bun debug",
      "type": "bun",
      "request": "launch",
      "runtime": "bun",
      "runtimeArgs": [
        "run",
        "-b",
        "--inspect-brk"
      ],
      "program": "${file}",
      "internalConsoleOptions": "openOnSessionStart",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "bun build debug",
      "type": "bun",
      "request": "launch",
      "runtime": "bun",
      "runtimeArgs": [
        "run",
        "build",
        "--inspect-brk"
      ],
      "program": "src/build/index.ts",
      "internalConsoleOptions": "openOnSessionStart",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
