{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://plainlicense.org/schemas/mapping/v1.0.0",
  "title": "License Clause Mapping Schema",
  "description": "Schema for mapping plain language license clauses to original legal text",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "license_id",
    "version",
    "mapping_philosophy",
    "mappings"
  ],
  "properties": {
    "license_id": {
      "type": "string",
      "description": "SPDX identifier or custom license ID",
      "examples": ["MIT", "MPL-2.0", "Elastic-2.0"]
    },
    "version": {
      "type": "string",
      "description": "Plain license version (from package.json)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["0.2.1", "1.0.0"]
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last mapping update"
    },
    "mapping_philosophy": {
      "type": "string",
      "description": "Approach to mapping",
      "enum": [
        "clause-level with interpretive correspondence",
        "section-level with strict translation",
        "custom"
      ]
    },
    "generation_method": {
      "type": "string",
      "description": "How mappings were created",
      "enum": ["manual", "ai-assisted", "ai-generated"]
    },
    "ai_model": {
      "type": "string",
      "description": "AI model used if ai-assisted or ai-generated",
      "examples": ["claude-3-5-sonnet", "gpt-4"]
    },
    "human_reviewed": {
      "type": "boolean",
      "description": "Whether human reviewed AI suggestions"
    },
    "semantic_tags": {
      "type": "object",
      "description": "Groups of clause IDs by semantic category",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "Clause ID"
        }
      },
      "examples": [
        {
          "permissions": ["plain-perm-use", "plain-perm-copy"],
          "warranty": ["plain-warranty-as-is"],
          "conditions": ["plain-cond-copyright"]
        }
      ]
    },
    "mappings": {
      "type": "array",
      "description": "Array of clause mappings",
      "items": {
        "$ref": "#/definitions/mapping"
      }
    },
    "validation": {
      "type": "object",
      "description": "Validation status and change tracking",
      "properties": {
        "tags_with_changes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Semantic tags with content changes since last validation"
        },
        "mappings_needing_review": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Mapping IDs that need human review due to content changes"
        },
        "last_content_hash_check": {
          "type": "string",
          "format": "date-time",
          "description": "When content hashes were last validated"
        },
        "validation_status": {
          "type": "string",
          "enum": ["valid", "needs_review", "invalid"],
          "description": "Overall validation status"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Statistics and metadata about mappings",
      "properties": {
        "total_mappings": {
          "type": "integer",
          "minimum": 0
        },
        "mapping_types": {
          "type": "object",
          "description": "Count of each mapping type",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "average_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Average confidence score across all mappings"
        },
        "human_review_time_minutes": {
          "type": "number",
          "minimum": 0,
          "description": "Total minutes spent on human review"
        },
        "ai_processing_time_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Total seconds for AI processing"
        },
        "completeness": {
          "type": "object",
          "properties": {
            "plain_clauses_mapped": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Percentage of plain clauses mapped"
            },
            "original_clauses_mapped": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Percentage of original clauses mapped"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "mapping": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique mapping identifier",
          "pattern": "^map-[a-z0-9-]+$",
          "examples": ["map-perm-use", "map-warranty-1"]
        },
        "type": {
          "type": "string",
          "enum": [
            "one-to-one",
            "one-to-one-expanded",
            "one-to-many",
            "many-to-one",
            "many-to-many",
            "unmapped-plain",
            "unmapped-original"
          ],
          "description": "Type of mapping relationship"
        },
        "plain_clause": {
          "oneOf": [
            {
              "$ref": "#/definitions/clause"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/clause"
              },
              "minItems": 1,
              "description": "Multiple plain clauses (for many-to-one, many-to-many)"
            },
            {
              "type": "null",
              "description": "Null for unmapped-original type"
            }
          ]
        },
        "original_clause": {
          "oneOf": [
            {
              "$ref": "#/definitions/clause"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/clause"
              },
              "minItems": 1,
              "description": "Multiple original clauses (for one-to-many, many-to-many)"
            },
            {
              "type": "null",
              "description": "Null for unmapped-plain type"
            }
          ]
        },
        "confidence": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence score (0.0 - 1.0)"
            },
            {
              "type": "null",
              "description": "Null for unmapped types"
            }
          ]
        },
        "expansion_type": {
          "type": "string",
          "enum": [
            "none",
            "educational-clarification",
            "legal-interpretation-with-examples",
            "restructuring"
          ],
          "description": "How plain language expands/interprets original"
        },
        "semantic_tag": {
          "type": "string",
          "description": "Primary semantic category",
          "examples": [
            "permissions",
            "warranty",
            "conditions",
            "liability",
            "termination",
            "definitions",
            "scope",
            "interpretation",
            "metadata"
          ]
        },
        "notes": {
          "type": "string",
          "description": "Human or AI explanation of mapping",
          "maxLength": 1000
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When mapping was created"
        },
        "created_by": {
          "type": "string",
          "enum": ["human", "ai-assisted", "ai-generated"],
          "description": "How mapping was created"
        },
        "last_validated": {
          "type": "string",
          "format": "date-time",
          "description": "When mapping was last validated"
        },
        "human_reviewed": {
          "type": "boolean",
          "description": "Whether human reviewed this mapping"
        },
        "reviewer_notes": {
          "type": ["string", "null"],
          "description": "Notes from human reviewer",
          "maxLength": 500
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["unmapped-plain", "unmapped-original"]
              }
            }
          },
          "then": {
            "properties": {
              "confidence": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "one-to-one"
              }
            }
          },
          "then": {
            "properties": {
              "confidence": {
                "type": "number",
                "minimum": 0.95
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "one-to-one-expanded"
              }
            }
          },
          "then": {
            "properties": {
              "confidence": {
                "type": "number",
                "minimum": 0.85
              }
            }
          }
        }
      ]
    },
    "clause": {
      "type": "object",
      "required": ["id", "hash", "content"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Semantic identifier (kebab-case)",
          "pattern": "^(plain|original)-[a-z0-9-]+$",
          "examples": [
            "plain-perm-use",
            "original-grant-use",
            "plain-warranty-as-is"
          ]
        },
        "semantic_tag": {
          "type": "string",
          "description": "Category: permissions, warranty, conditions, etc.",
          "examples": [
            "permissions",
            "permissions:commercial",
            "warranty",
            "warranty:as-is",
            "conditions",
            "conditions:attribution"
          ]
        },
        "hash": {
          "type": "string",
          "description": "SHA-256 hash of normalized content",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "examples": ["sha256:a1b2c3d4e5f6..."]
        },
        "content": {
          "type": "string",
          "description": "Raw clause text (preserves markdown)",
          "minLength": 1,
          "maxLength": 5000
        },
        "context": {
          "type": "string",
          "description": "Surrounding text (heading, list intro)",
          "maxLength": 500
        },
        "content_normalized": {
          "type": "string",
          "description": "Content with markdown stripped",
          "maxLength": 5000
        },
        "content_preview": {
          "type": "string",
          "description": "Truncated for display",
          "maxLength": 100
        },
        "line_start": {
          "type": "integer",
          "minimum": 1,
          "description": "Starting line number in source file"
        },
        "line_end": {
          "type": "integer",
          "minimum": 1,
          "description": "Ending line number in source file"
        },
        "section_heading": {
          "type": "string",
          "description": "Parent section title",
          "maxLength": 200
        },
        "is_list_item": {
          "type": "boolean",
          "description": "True if part of list"
        },
        "markdown_preserved": {
          "type": "boolean",
          "description": "Whether content includes markdown formatting"
        },
        "annotations": {
          "type": "array",
          "description": "Editorial annotations (not hashed)",
          "items": {
            "type": "object",
            "properties": {
              "marker": {
                "type": "string",
                "description": "Reference marker like (1), (2)",
                "examples": ["(1)", "(2)", "(a)"]
              },
              "text": {
                "type": "string",
                "description": "Annotation text",
                "maxLength": 500
              }
            }
          }
        }
      }
    }
  }
}
