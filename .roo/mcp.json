{
  "mcpServers": {
    "cloudflare": {
      "alwaysAllow": [],
      "disabled": true,
      "type": "sse",
      "url": "https://docs.mcp.cloudflare.com/sse"
    },
    "console-ninja": {
      "alwaysAllow": [],
      "args": ["--bun", "~/.console-ninja/mcp/"],
      "command": "bunx",
      "disabled": true,
      "type": "stdio"
    },
    "context7": {
      "alwaysAllow": ["resolve-library-id", "get-library-docs"],
      "args": ["--bun", "@upstash/context7-mcp@latest"],
      "command": "bunx",
      "type": "stdio"
    },
    "fetch": {
      "args": ["mcp-server-fetch"],
      "command": "uvx"
    },
    "filesystem": {
      "args": ["--bun", "@modelcontextprotocol/server-filesystem", "~/knitli/plainlicense"],
      "command": "bunx"
    },
    "mem0-memory-mcp": {
      "args": [
        "--bun",
        "@smithery/cli@latest",
        "run",
        "@mem0ai/mem0-memory-mcp",
        "--key",
        "${env:MEM0}",
        "--profile",
        "${env:SMITHERY_PROFILE}"
      ],
      "command": "bunx"
    },
    "playwright": {
      "args": [
        "--bun",
        "@playwright/mcp@latest",
        "--browser",
        "/mnt/c/Users/bm-sv/scoop/shims/chromium.exe"
      ],
      "command": "bunx"
    },
    "sequential-thinking": {
      "alwaysAllow": ["sequentialthinking"],
      "args": ["--bun", "@modelcontextprotocol/server-sequential-thinking"],
      "command": "bunx",
      "type": "stdio"
    }
  }
}
