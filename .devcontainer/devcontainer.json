// For format details, see https://aka.ms/devcontainer.json. For config options, see the
{
	"name": "Ubuntu",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		6000,
		6499,
		7890,
		8000,
		9222
	],
	"features": {
		"ghcr.io/va-h/devcontainers-features/uv:1": {
			"shellautocompletion": true
		},
		"ghcr.io/devcontainers-extra/features/ripgrep:1": {}
	},
	"portsAttributes": {
		"6499": {
			"label": "Bun debug"
		},
		"6000": {
			"label": "Firefox debug server",
			"protocol": "http",
			"icon": "firefox",
			"onAutoForward": "notify",
			"elevateIfNeeded": true
		},
		"7890": {
			"label": "http proxy",
			"protocol": "http",
			"icon": "globe"
		},
		"8000": {
			"label": "MKDocs dev server",
			"protocol": "http",
			"icon": "globe",
			"openMode": "openBrowser",
			"onAutoForward": "openBrowserOnce",
			"elevateIfNeeded": true
		},
		"9222": {
			"label": "Chrome debug server",
			"protocol": "http",
			"icon": "chrome",
			"elevateIfNeeded": true
		}
	},
	"runArgs": [
		"--dns",
		"1.1.1.2",
		"--dns",
		"1.0.0.2",
		"--dns",
		"103.247.36.36",
		"--dns",
		"103.247.37.37"
	],
	"containerEnv": {
		"UV_LINK_MODE": "copy",
		"UV_COMPILE_BYTECODE": "1",
		"FORCE_COLOR": "1",
		"CLICOLOR_FORCE": "1",
		"UV_PYTHON": "cpython-3.13.0-linux-x86_64-gnu",
		"UV_PYTHON_PREFERENCE": "managed",
		"UV_PYTHON_DOWNLOADS": "automatic",
		"PYVENV": "/workspaces/plainlicense/.venv/bin/activate",
		"UV_CACHE_DIR": "/workspaces/plainlicense/.cache/uv"
	},
	"postCreateCommand": "chmod +x /workspaces/plainlicense/.devcontainer/container-setup.sh && /workspaces/plainlicense/.devcontainer/container-setup.sh",
	// Features to add to the dev container. More info: https://containers.dev/features.
	"customizations": {
		"vscode": {
			"extensions": [
				"Alexey-Strakh.stackoverflow-search",
				"DavidAnson.vscode-markdownlint",
				"Mukundan.python-docs",
				"PascalReitermann93.vscode-yaml-sort",
				"Tock.vscode-css-custom-properties",
				"Tyriar.sort-lines",
				"VisualStudioExptTeam.intellicode-api-usage-examples",
				"VisualStudioExptTeam.vscodeintellicode",
				"WallabyJs.quokka-vscode",
				"WallabyJs.wallaby-vscode",
				"YoavBls.pretty-ts-errors",
				"ZainChen.json",
				"Zignd.html-css-class-completion",
				"aaron-bond.better-comments",
				"akmarnafi.comment-headers",
				"almenon.birdseye-vscode",
				"anteprimorac.html-end-tag-labels",
				"antfu.iconify",
				"charliermarsh.ruff",
				"christian-kohler.npm-intellisense",
				"christian-kohler.path-intellisense",
				"cmstead.js-codeformer",
				"cmstead.jsrefactor",
				"dbaeumer.vscode-eslint",
				"donjayamanne.githistory",
				"donjayamanne.python-environment-manager",
				"donjayamanne.python-extension-pack",
				"ecmel.vscode-html-css",
				"eriklynd.json-tools",
				"evgeniypeshkov.syntax-highlighter",
				"fill-labs.dependi",
				"firefox-devtools.vscode-firefox-debug",
				"formulahendry.auto-rename-tag",
				"github.vscode-github-actions",
				"hbenl.vscode-test-explorer",
				"jock.svg",
				"kakumei.ts-debug",
				"kamikillerto.vscode-linthtml",
				"leizongmin.node-module-intellisense",
				"littlefoxteam.vscode-python-test-adapter",
				"mads-hartmann.bash-ide-vscode",
				"minherz.copyright-inserter",
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-vscode.test-adapter-converter",
				"njpwerner.autodocstring",
				"njqdev.vscode-python-typehint",
				"oderwat.indent-rainbow",
				"oven.bun-vscode",
				"pamaron.pytest-runner",
				"qcz.text-power-tools",
				"redhat.vscode-yaml",
				"remcohaszing.schemastore",
				"rogalmic.bash-debug",
				"rvest.vs-code-prettier-eslint",
				"shakram02.bash-beautify",
				"sketchbuch.vsc-quokka-statusbar",
				"sourcery.sourcery",
				"stylelint.vscode-stylelint",
				"tamasfe.even-better-toml",
				"tberman.json-schema-validator",
				"tekumara.typos-vscode",
				"timonwong.shellcheck",
				"travis71i.clean-css-vscode",
				"wholroyd.jinja",
				"wix.vscode-import-cost",
				"wmontalvo.vsc-jsonsnippets",
				"yzhang.markdown-all-in-one",
				"foxundermoon.shell-format",
				"Perkovec.emoji",
				"bierner.markdown-emoji",
				"Gydunhn.vsc-essentials",
				"bierner.emojisense",
				"1YiB.rust-bundle"
			]
		}
	}
}
