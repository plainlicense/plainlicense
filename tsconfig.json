{
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "baseUrl": "./",
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react",
    "jsxFactory": "h",
    "lib": ["DOM", "DOM.Iterable", "WebWorker", "es2018", "es2020", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "docs/assets/",
    "paths": {
      "_/*": ["./external/mkdocs-material/material/overrides/assets/javascripts/*"],
      "@/*": ["./external/mkdocs-material/src/templates/assets/javascripts/*"],
      "~/*": [
        "./src/assets/javascripts/*",
        "./external/mkdocs-material/src/templates/assets/javascripts/*"
      ],
      "~assets/*": ["./src/assets/*"],
      "~external/*": ["./typings"]
    },
    "removeComments": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "stripInternal": true,
    "target": "es2020",
    "verbatimModuleSyntax": false,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  },
  "exclude": ["src/build/*.ts", "./commitlint.config.ts", "dist"],
  "extends": "@tsconfig/bun/tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.astro",
    "./external/mkdocs-material/typings",
    "./external/mkdocs-material/material/src/templates/assets/javascripts/bundle.ts",
    "./external/mkdocs-material/material/src/templates/assets/javascripts/**/*.ts",
    "./external/mkdocs-material/material/src/overrides/assets/javascripts/**/*.ts",
    "src/cacheWorker.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.build.json"
    },
    {
      "path": "./tsconfig.commitlint.json"
    }
  ]
}
